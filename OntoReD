    <!-- http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#Preparado -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#Preparado">
        <rdf:type rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#EstadoAlpha"/>
        <untitled-ontology-3:avancadoPor rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#PrepararParteCasoUso"/>
        <untitled-ontology-3:Icone>&lt;p&gt;Icone Estado Alpha&lt;/p&gt;</untitled-ontology-3:Icone>
        <untitled-ontology-3:descricao>&lt;ul&gt;
    &lt;li style=&quot;font-size: 12px; text-align: justify;&quot;&gt;&lt;span style=&quot;text-align: left; color: rgb(0, 0, 0);&quot;&gt;&lt;strong&gt;A fatia do caso de uso foi preparada aprimorando a &lt;span style=&apos;color: rgb(0, 0, 0); font-family: &quot;Times New Roman&quot;; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; background-color: rgb(255, 255, 255); text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; float: none; display: inline !important;&apos;&gt;narrativa&amp;nbsp;&lt;/span&gt; e os casos de teste para definir claramente o que significa implementar a fatia com sucesso.&lt;/strong&gt;&lt;/span&gt;&lt;/li&gt;
    &lt;li style=&quot;font-size: 12px; text-align: justify;&quot;&gt;&lt;strong&gt;Os requisitos dentro do escopo s&amp;atilde;o acordados:&amp;nbsp;&lt;/strong&gt;Os fluxos de casos de uso no escopo, os requisitos especiais e as informa&amp;ccedil;&amp;otilde;es de apoio foram detalhados o suficiente para serem acordados pelas partes interessadas relevantes e pela equipe do projeto.&amp;nbsp;&lt;/li&gt;
    &lt;li style=&quot;font-size: 12px; text-align: justify;&quot;&gt;&lt;strong&gt;Os casos de teste s&amp;atilde;o suficientes para verifica&amp;ccedil;&amp;atilde;o:&amp;nbsp;&lt;/strong&gt;O(s) caso(s) de teste fornecem informa&amp;ccedil;&amp;otilde;es suficientes para que n&amp;atilde;o haja d&amp;uacute;vidas sobre os testes a serem executados para verificar o sucesso da implementa&amp;ccedil;&amp;atilde;o da fatia.&amp;nbsp;&lt;/li&gt;
    &lt;li style=&quot;font-size: 12px; text-align: justify;&quot;&gt;&lt;strong&gt;Os testes s&amp;atilde;o bem definidos:&lt;/strong&gt; Os testes foram definidos com amplitude e profundidade suficientes, com crit&amp;eacute;rios de aceita&amp;ccedil;&amp;atilde;o claros, para verificar se o sistema funciona conforme especificado pela fatia. &lt;/li&gt;
&lt;/ul&gt;</untitled-ontology-3:descricao>
        <untitled-ontology-3:nome>&lt;p&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;&lt;strong&gt;Preparado&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;</untitled-ontology-3:nome>
        <untitled-ontology-3:sequencia rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">2</untitled-ontology-3:sequencia>
    </owl:NamedIndividual>
    


