    <!-- http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#DefinirTecnicaRastreabilRequisitos -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#DefinirTecnicaRastreabilRequisitos">
        <rdf:type rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#PassosElementosPrática"/>
        <untitled-ontology-3:estaContidoEm rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#ModeloRastreabilidade"/>
        <untitled-ontology-3:descricao>&lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&apos;font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;As informa&amp;ccedil;&amp;otilde;es presentes na rastreabilidade de requisitos podem ser representadas por refer&amp;ecirc;ncias textuais, hyperlinks, matriz de rastreabilidade e grafos de rastreabilidade.&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Ap&amp;oacute;s definir o tipo de rastreabilidade e sua finalidade&lt;/span&gt;&lt;/strong&gt;&lt;/span&gt;&lt;span style=&apos;font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;, deve-se definir a t&amp;eacute;cnica que ser&amp;aacute; usada para implementar a rastreabilidade.&lt;/span&gt;&lt;/p&gt;
&lt;ul&gt;
    &lt;li style=&quot;list-style-type:disc;font-size:10pt;font-family:&apos;Times New Roman&apos;,serif;&quot;&gt;
        &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Refer&amp;ecirc;ncias textuais e hyperlinks:&lt;/span&gt;&lt;/strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;&amp;nbsp;Consiste em sinalizar o artefato alvo como uma refer&amp;ecirc;ncia textual no requisito, registrada no artefato inicial ou vincular hyperlinks entre o artefato inicial e o artefato alvo. Conectando artefatos, diferentes hyperlinks com conex&amp;otilde;es sem&amp;acirc;nticas espec&amp;iacute;ficas podem ser consideradas &lt;span style=&quot;font-size: 8px;&quot;&gt;(&lt;span style=&quot;font-size:10pt;font-family:&apos;Times New Roman&apos;,serif;&quot;&gt;&lt;span style=&quot;font-size:10pt;font-family:&apos;Times New Roman&apos;,serif;&quot;&gt;&lt;span style=&quot;font-size:8pt;font-family:&apos;Times New Roman&apos;,serif;&quot;&gt;Pohl; Rupp 2015&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;).&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;
    &lt;/li&gt;
    &lt;li style=&quot;list-style-type:disc;font-size:10pt;font-family:&apos;Times New Roman&apos;,serif;&quot;&gt;
        &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&apos;font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;&lt;strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Matriz de rastreabilidade:&lt;/span&gt;&lt;/strong&gt;&lt;/span&gt;&lt;span style=&quot;font-size:10pt;font-family:&apos;Times New Roman&apos;,serif;&quot;&gt;&lt;span style=&apos;font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;&amp;nbsp;Uma matriz de rastreabilidade visa a representa&amp;ccedil;&amp;atilde;o da rela&amp;ccedil;&amp;atilde;o entre os requisitos e outros artefatos da engenharia de software, sendo composta por linhas e colunas&lt;/span&gt;&lt;span style=&quot;font-size:10pt;font-family:&apos;Times New Roman&apos;,serif;&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;/span&gt;&lt;span style=&apos;font-size: 8px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;(Pressman; Maxim2021)&lt;/span&gt;&lt;/span&gt;&lt;span style=&quot;font-size:10pt;font-family:&apos;Times New Roman&apos;,serif;&quot;&gt;&lt;span style=&apos;font-size: 8px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;.&lt;/span&gt;&lt;span style=&quot;font-size:10pt;font-family:&apos;Times New Roman&apos;,serif;&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;
    &lt;/li&gt;
    &lt;li style=&quot;list-style-type:disc;font-size:10pt;font-family:&apos;Times New Roman&apos;,serif;&quot;&gt;
        &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;font-size:10pt;font-family:&apos;Times New Roman&apos;,serif;&quot;&gt;&lt;span style=&apos;font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;&lt;strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Grafos de rastreabilidade:&lt;/span&gt;&lt;/strong&gt;&lt;/span&gt;&lt;span style=&quot;font-size:10pt;font-family:&apos;Times New Roman&apos;,serif;&quot;&gt;&lt;span style=&apos;font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;&amp;nbsp;Grafo no qual os seus n&amp;oacute;s representam artefatos e as linhas, os relacionamentos entre os artefatos&lt;/span&gt;&lt;span style=&quot;font-size:10pt;font-family:&apos;Times New Roman&apos;,serif;&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;font-size:8pt;font-family:&apos;Times New Roman&apos;,serif;&quot;&gt;(Pohl; Rupp 2015)&lt;/span&gt;&lt;span style=&quot;font-size:10pt;font-family:&apos;Times New Roman&apos;,serif;&quot;&gt;.&amp;nbsp;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;
    &lt;/li&gt;
&lt;/ul&gt;</untitled-ontology-3:descricao>
        <untitled-ontology-3:nome>&lt;p style=&quot;text-align: center;&quot;&gt;&lt;strong&gt;&lt;span style=&quot;font-size:11pt;font-family:&apos;Times New Roman&apos;,serif;&quot;&gt;Definir uma t&amp;eacute;cnica para rastreabilidade de requisitos&lt;/span&gt;&lt;/strong&gt;&lt;/p&gt;</untitled-ontology-3:nome>
        <untitled-ontology-3:sequencia rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">3</untitled-ontology-3:sequencia>
