    <!-- http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#AnalisarParteCasoUso -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#AnalisarParteCasoUso">
        <rdf:type rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#AtividadeProdutoTrabalho"/>
        <untitled-ontology-3:produz rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#RealizacaoCasoUso"/>
        <untitled-ontology-3:Icone>&lt;p&gt;Icone Atividade Produto Trabalho&lt;/p&gt;</untitled-ontology-3:Icone>
        <untitled-ontology-3:abordagens>&lt;div style=&quot;text-align: justify; color: rgb(0, 0, 0); font-size: 16px;&quot;&gt;
    &lt;p style=&quot;font-size: 1em; text-align: justify;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;Os objetivos da atividade podem ser alcan&amp;ccedil;ados de diversas maneiras, incluindo:&lt;/strong&gt;&lt;br&gt;1) discuss&amp;otilde;es em equipe e documenta&amp;ccedil;&amp;atilde;o centrada em c&amp;oacute;digo;&lt;br&gt;2) desenhos informais e documenta&amp;ccedil;&amp;atilde;o centrada em c&amp;oacute;digo e;&lt;br&gt;3) modelagem visual com rastreabilidade expl&amp;iacute;cita dentro da fatia do caso de uso; desde narrativas de casos de uso at&amp;eacute; realiza&amp;ccedil;&amp;otilde;es de casos de uso e at&amp;eacute; o pr&amp;oacute;prio c&amp;oacute;digo. A atividade tamb&amp;eacute;m pode ser conduzida para abordar quest&amp;otilde;es de an&amp;aacute;lise ou de projeto.&lt;/span&gt;&lt;/p&gt;________________&lt;br&gt;
    &lt;h2 style=&quot;font-size: 1.75em; text-align: center;&quot;&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;&lt;u&gt;CRC baseado em casos de uso&lt;/u&gt;&lt;/span&gt;&lt;/h2&gt;
    &lt;p style=&quot;font-size: 1em; text-align: justify;&quot;&gt;&lt;strong&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Use essa abordagem para a maioria das hist&amp;oacute;rias.&lt;/span&gt;&lt;/strong&gt;&lt;/p&gt;
    &lt;p style=&quot;font-size: 1em; text-align: justify;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;CRC &amp;eacute; um acr&amp;ocirc;nimo para Classe, Responsabilidades e Colabora&amp;ccedil;&amp;atilde;o; esta &amp;eacute; uma t&amp;eacute;cnica para analisar e projetar software. A abordagem CRC sugere que seja criado um cart&amp;atilde;o para cada turma, onde sejam listadas as responsabilidades e as colabora&amp;ccedil;&amp;otilde;es dessa turma.&lt;/span&gt;&lt;/p&gt;
    &lt;p style=&quot;font-size: 1em; text-align: justify;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;Sugere-se que a abordagem CRC seja usada da seguinte maneira:&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;
    &lt;ul&gt;
        &lt;li style=&quot;font-size: 12px; text-align: justify;&quot;&gt;Deve haver um cart&amp;atilde;o para cada elemento principal de implementa&amp;ccedil;&amp;atilde;o.&amp;nbsp;Esses cart&amp;otilde;es podem ser eletr&amp;ocirc;nicos, coment&amp;aacute;rios de c&amp;oacute;digos impressos, Post-it&amp;reg;Notes ou cart&amp;otilde;es de pr&amp;aacute;tica.&lt;/li&gt;
        &lt;li style=&quot;font-size: 12px; text-align: justify;&quot;&gt;Cada cart&amp;atilde;o deve listar todas as coisas que o elemento precisa fazer (isto &amp;eacute;, suas responsabilidades) nas hist&amp;oacute;rias em que est&amp;aacute; envolvido.&lt;/li&gt;
    &lt;/ul&gt;
    &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;&amp;Agrave; medida que as hist&amp;oacute;rias s&amp;atilde;o analisadas para um caso de uso, &amp;eacute; necess&amp;aacute;rio fazer o seguinte:&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;
    &lt;ol&gt;
        &lt;li style=&quot;font-size: 12px; text-align: justify;&quot;&gt;Cole os cart&amp;otilde;es em um quadro branco.&lt;/li&gt;
        &lt;li style=&quot;font-size: 12px; text-align: justify;&quot;&gt;Leia os fluxos relevantes na narrativa do caso de uso.&lt;/li&gt;
        &lt;li style=&quot;font-size: 12px; text-align: justify;&quot;&gt;Use uma caneta para desenhar um caminho para o fluxo atrav&amp;eacute;s dos cart&amp;otilde;es no quadro branco.&lt;/li&gt;
        &lt;li style=&quot;font-size: 12px; text-align: justify;&quot;&gt;Sugira e anote quaisquer responsabilidades adicionadas ou alteradas para os cart&amp;otilde;es.&lt;/li&gt;
        &lt;li style=&quot;font-size: 12px; text-align: justify;&quot;&gt;Discuta o impacto, as consequ&amp;ecirc;ncias e as solu&amp;ccedil;&amp;otilde;es alternativas.&amp;nbsp;Concorde com uma solu&amp;ccedil;&amp;atilde;o.&lt;/li&gt;
        &lt;li style=&quot;font-size: 12px; text-align: justify;&quot;&gt;Tire uma foto do fluxo com uma c&amp;acirc;mera digital e adicione-a como documenta&amp;ccedil;&amp;atilde;o.&lt;/li&gt;
        &lt;li style=&quot;text-align: justify; font-size: 12px;&quot;&gt;Obviamente, esta abordagem pode ser usada com ferramentas mais sofisticadas, como aplicativos em nuvem ou tablets.&lt;/li&gt;
    &lt;/ol&gt;
    &lt;p style=&quot;font-size: 1em; text-align: justify;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Essa abordagem &amp;eacute; muito flex&amp;iacute;vel e pode ser variada para atender &amp;agrave;s necessidades da equipe.&lt;/span&gt;&lt;/p&gt;
    &lt;p style=&quot;font-size: 1em; text-align: justify;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;________________&lt;/span&gt;&lt;/p&gt;
    &lt;div style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 16px;&quot;&gt;
        &lt;h2 style=&quot;font-size: 1.75em; text-align: center;&quot;&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;&lt;strong&gt;&lt;u&gt;Sugerir conjunto inicial de elementos&lt;/u&gt;&lt;/strong&gt;&lt;/span&gt;&lt;/h2&gt;
        &lt;ul&gt;
            &lt;li style=&quot;font-size: 1em; text-align: justify;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;Considerar esta abordagem no in&amp;iacute;cio do projeto para gerar um conjunto inicial de elementos de implementa&amp;ccedil;&amp;atilde;o.&lt;/strong&gt;&lt;/span&gt;&lt;/li&gt;
            &lt;li style=&quot;font-size: 1em; text-align: justify;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Selecionar alguns casos de uso e hist&amp;oacute;rias importantes, mas bastante diferentes. Use a abordagem &amp;ldquo;CRC orientado a casos de uso&amp;rdquo; para gerar um conjunto de elementos de implementa&amp;ccedil;&amp;atilde;o com responsabilidades iniciais.&lt;/span&gt;&lt;/li&gt;
            &lt;li style=&quot;font-size: 1em; text-align: justify;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Use este conjunto inicial de elementos de implementa&amp;ccedil;&amp;atilde;o para preparar o restante do trabalho orientado a casos de uso.&lt;/span&gt;&lt;/li&gt;
        &lt;/ul&gt;
    &lt;/div&gt;
    &lt;div style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 16px;&quot;&gt;
        &lt;h2 style=&quot;font-size: 1.75em; text-align: justify;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;________________&lt;/span&gt;&lt;/h2&gt;
        &lt;h2 style=&quot;font-size: 1.75em; text-align: center;&quot;&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;&lt;u&gt;Pensar em responsabilidades&lt;/u&gt;&lt;/span&gt;&lt;/h2&gt;
        &lt;ul&gt;
            &lt;li style=&quot;font-size: 1em; text-align: justify;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;Considerar esta abordagem para casos de uso e hist&amp;oacute;rias que n&amp;atilde;o sejam cr&amp;iacute;ticas.&lt;/strong&gt;&lt;/span&gt;&lt;/li&gt;
            &lt;li style=&quot;font-size: 1em; text-align: justify;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Esta &amp;eacute; uma alternativa muito leve &amp;agrave; abordagem CRC baseada em hist&amp;oacute;rias que usa apenas as etapas 2, 4 e possivelmente 5 da abordagem &amp;ldquo;CRC orientada por casos de uso&amp;rdquo;. Os pr&amp;oacute;prios cart&amp;otilde;es CRC podem ser descartados com as responsabilidades sugeridas anotadas diretamente nos coment&amp;aacute;rios do c&amp;oacute;digo.&lt;/span&gt;&lt;/li&gt;
        &lt;/ul&gt;
    &lt;/div&gt;
    &lt;div style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 16px;&quot;&gt;
        &lt;h2 style=&quot;font-size: 1.75em; text-align: justify;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;________________&lt;/span&gt;&lt;/h2&gt;
        &lt;h2 style=&quot;font-size: 1.75em; text-align: center;&quot;&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;&lt;u&gt;Analisar e design de casos de uso cl&amp;aacute;ssicos&lt;/u&gt;&lt;/span&gt;&lt;/h2&gt;
        &lt;ul&gt;
            &lt;li style=&quot;font-size: 1em; text-align: justify;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;Use esta abordagem quando for importante ter um alto grau de rastreabilidade desde os casos de uso at&amp;eacute; o c&amp;oacute;digo.&lt;/strong&gt;&lt;/span&gt;&lt;/li&gt;
            &lt;li style=&quot;font-size: 1em; text-align: justify;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Esta abordagem &amp;eacute; em muitos aspectos semelhante &amp;agrave; abordagem &amp;ldquo;CRC orientado a casos de uso&amp;rdquo;, exceto que a comunica&amp;ccedil;&amp;atilde;o UML ou diagramas de sequ&amp;ecirc;ncia s&amp;atilde;o usados para descrever a realiza&amp;ccedil;&amp;atilde;o de cada fluxo. Conecte cada mensagem no(s) diagrama(s) &amp;agrave; responsabilidade ou opera&amp;ccedil;&amp;atilde;o do elemento correspondente.&lt;/span&gt;&lt;/li&gt;
        &lt;/ul&gt;
    &lt;/div&gt;
&lt;/div&gt;</untitled-ontology-3:abordagens>
        <untitled-ontology-3:apresAtividade>&lt;div style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 16px;&quot;&gt;
    &lt;ul&gt;
        &lt;li style=&quot;text-align: justify; color: rgb(0, 0, 0); font-size: 16px;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Esta atividade resulta na cria&amp;ccedil;&amp;atilde;o ou atualiza&amp;ccedil;&amp;atilde;o da realiza&amp;ccedil;&amp;atilde;o de caso de uso que descreve como o caso de uso &amp;eacute; implementado.&lt;/span&gt;&lt;/li&gt;
        &lt;li style=&quot;text-align: justify; color: rgb(0, 0, 0); font-size: 16px;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Quando uma equipe recebe uma nova fatia para implementar, a primeira coisa a fazer &amp;eacute; descobrir como ela afetar&amp;aacute; o sistema.&amp;nbsp;Quantos bits do sistema precisar&amp;atilde;o ser alterados e de que maneira?&amp;nbsp;Quantas coisas novas s&amp;atilde;o necess&amp;aacute;rias e onde elas se encaixam?&lt;/span&gt;&lt;/li&gt;
        &lt;li style=&quot;text-align: justify; color: rgb(0, 0, 0); font-size: 16px;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;A an&amp;aacute;lise das fatias alvo costuma ser um precursor do planejamento das tarefas de desenvolvimento.&amp;nbsp;Ele permite que a equipe planeje a implementa&amp;ccedil;&amp;atilde;o da fatia como um conjunto de pequenas altera&amp;ccedil;&amp;otilde;es de c&amp;oacute;digo, em vez de como uma pe&amp;ccedil;a grande e indivis&amp;iacute;vel de trabalho.&amp;nbsp;Alternativamente, a pr&amp;oacute;pria fatia pode ser usada como unidade de trabalho e a an&amp;aacute;lise da fatia &amp;eacute; apenas a &amp;uacute;ltima coisa a ser realizada pelo desenvolvedor antes do in&amp;iacute;cio da codifica&amp;ccedil;&amp;atilde;o.&lt;/span&gt;&lt;/li&gt;
        &lt;li style=&quot;text-align: justify; color: rgb(0, 0, 0); font-size: 16px;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&amp;Agrave; medida que a equipe desenvolve sua compreens&amp;atilde;o do sistema e de sua arquitetura, eles achar&amp;atilde;o cada vez mais f&amp;aacute;cil analisar as fatias e muitas vezes ser&amp;atilde;o capazes de fazer isso mentalmente.&amp;nbsp;Ainda vale a pena esbo&amp;ccedil;ar a an&amp;aacute;lise com alguns colegas antes de iniciar a codifica&amp;ccedil;&amp;atilde;o.&amp;nbsp;Isto validar&amp;aacute; muitas das decis&amp;otilde;es de design, verificar&amp;aacute; se nada foi mal compreendido e fornecer&amp;aacute; rastreabilidade para uso posterior ao investigar o impacto das altera&amp;ccedil;&amp;otilde;es.&amp;nbsp;O resultado desse tipo de an&amp;aacute;lise &amp;eacute; conhecido como realiza&amp;ccedil;&amp;atilde;o de caso de uso porque mostra como o caso de uso &amp;eacute; realizado pelos elementos do sistema de implementa&amp;ccedil;&amp;atilde;o.&lt;/span&gt;&lt;/li&gt;
        &lt;li style=&quot;text-align: justify; color: rgb(0, 0, 0); font-size: 16px;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Executar esta atividade pelo menos uma vez para cada fatia. Repita esta atividade sempre que houver altera&amp;ccedil;&amp;otilde;es aplicadas &amp;agrave; fatia.&lt;/span&gt;&lt;/li&gt;
    &lt;/ul&gt;
&lt;/div&gt;</untitled-ontology-3:apresAtividade>
        <untitled-ontology-3:descricao>&lt;div style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 16px;&quot;&gt;
    &lt;p style=&quot;font-size: 1em; text-align: justify;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;Analisar o impacto de uma fatia de Caso de Uso e modelar sua implementa&amp;ccedil;&amp;atilde;o. (Pode ser ignorado se a implementa&amp;ccedil;&amp;atilde;o for trivial).&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;
&lt;/div&gt;
&lt;div style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 16px;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;Antes de come&amp;ccedil;ar a codificar, deve-se analisar uma fatia de caso de uso para:&lt;/strong&gt;&lt;/span&gt;&lt;/div&gt;
&lt;ul style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 16px;&quot;&gt;
    &lt;li style=&quot;font-size: 12px;&quot;&gt;Entender seu impacto nos elementos do sistema.&lt;/li&gt;
    &lt;li style=&quot;font-size: 12px;&quot;&gt;Definir as responsabilidades dos elementos do sistema afetados.&lt;/li&gt;
    &lt;li style=&quot;font-size: 12px;&quot;&gt;Definir como os elementos do sistema interagem para executar o caso de uso.&lt;/li&gt;
&lt;/ul&gt;</untitled-ontology-3:descricao>
        <untitled-ontology-3:infAdicionais>&lt;h2 style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 1.75em;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;u&gt;Participantes&lt;/u&gt;&lt;/span&gt;&lt;/h2&gt;
&lt;h3 style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 1.3125em;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Desenvolvimento&lt;/span&gt;&lt;/h3&gt;
&lt;p style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 16px;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;O respons&amp;aacute;vel por esta atividade dever&amp;aacute;:&lt;/span&gt;&lt;/p&gt;
&lt;ul style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 16px;&quot;&gt;
    &lt;li style=&quot;font-size: 12px;&quot;&gt;Entender o impacto do caso de uso nos elementos de implementa&amp;ccedil;&amp;atilde;o.&lt;/li&gt;
    &lt;li style=&quot;font-size: 12px;&quot;&gt;Definir as responsabilidades dos elementos de implementa&amp;ccedil;&amp;atilde;o &amp;agrave; medida que contribuem para a realiza&amp;ccedil;&amp;atilde;o do caso de uso.&lt;/li&gt;
    &lt;li style=&quot;font-size: 12px;&quot;&gt;Definir como os elementos de implementa&amp;ccedil;&amp;atilde;o interagem para realizar a hist&amp;oacute;ria contada pelo caso de uso.&lt;/li&gt;
&lt;/ul&gt;
&lt;p style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 16px;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&amp;Eacute; aconselh&amp;aacute;vel coordenar o trabalho de design deste caso de uso com a implementa&amp;ccedil;&amp;atilde;o geral.&amp;nbsp;Isto dever&amp;aacute; envolver a coopera&amp;ccedil;&amp;atilde;o com algu&amp;eacute;m respons&amp;aacute;vel pela configura&amp;ccedil;&amp;atilde;o geral do sistema.&lt;/span&gt;&lt;/p&gt;
&lt;h2 style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 1.75em;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;u&gt;Dicas e sugest&amp;otilde;es&lt;/u&gt;&lt;/span&gt;&lt;/h2&gt;
&lt;h3 style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 1.3125em;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Mantenha a an&amp;aacute;lise colaborativa e leve&lt;/span&gt;&lt;/h3&gt;
&lt;ul&gt;
    &lt;li style=&quot;text-align: justify; color: rgb(0, 0, 0); font-size: 16px;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;A maneira mais f&amp;aacute;cil de analisar a fatia do caso de uso &amp;eacute; reunir a equipe para discutir como isso afetaria os v&amp;aacute;rios elementos do sistema.&lt;/span&gt;&lt;/li&gt;
    &lt;li style=&quot;text-align: justify; color: rgb(0, 0, 0); font-size: 16px;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&amp;Agrave; medida que a equipe percorre o projeto, eles o retratam em um quadro branco, normalmente na forma de uma sequ&amp;ecirc;ncia simples ou de um diagrama de colabora&amp;ccedil;&amp;atilde;o, que pode ent&amp;atilde;o ser capturado como uma fotografia ou na ferramenta de modelagem escolhida pela equipe.&lt;/span&gt;&lt;/li&gt;
&lt;/ul&gt;
&lt;h3 style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 1.3125em;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Desenvolvimento de pares&lt;/span&gt;&lt;/h3&gt;
&lt;ul&gt;
    &lt;li style=&quot;text-align: justify; color: rgb(0, 0, 0); font-size: 16px;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Utilize este formul&amp;aacute;rio de trabalho quando o conhecimento sobre o neg&amp;oacute;cio, dom&amp;iacute;nio ou solu&amp;ccedil;&amp;atilde;o for limitado a apenas alguns membros da equipe&lt;/span&gt;&lt;/li&gt;
    &lt;li style=&quot;text-align: justify; color: rgb(0, 0, 0); font-size: 16px;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Os desenvolvedores trabalham em pares com outros desenvolvedores ou testadores. Esta atividade &amp;eacute; ent&amp;atilde;o realizada pelos membros da equipe, revezando-se, com uma pessoa analisando a fatia do caso de uso enquanto a outra reflete, faz perguntas e sugere alternativas. Ent&amp;atilde;o eles trocam de pap&amp;eacute;is.&lt;/span&gt;&lt;/li&gt;
&lt;/ul&gt;
&lt;h2 style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 1.75em;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;u&gt;Erros comuns&lt;/u&gt;&lt;/span&gt;&lt;/h2&gt;
&lt;h3 style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 1.3125em;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Detalhe irrelevante&lt;/span&gt;&lt;/h3&gt;
&lt;ul&gt;
    &lt;li style=&quot;text-align: justify; color: rgb(0, 0, 0); font-size: 16px;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&amp;Eacute; muito f&amp;aacute;cil come&amp;ccedil;ar a elaborar a realiza&amp;ccedil;&amp;atilde;o da fatia de casos de uso com detalhes sobre par&amp;acirc;metros, associa&amp;ccedil;&amp;otilde;es e atributos.&lt;/span&gt;&lt;/li&gt;
    &lt;li style=&quot;text-align: justify; color: rgb(0, 0, 0); font-size: 16px;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;&lt;strong&gt;Problema&lt;/strong&gt;&lt;/strong&gt; : Embora esta seja uma tend&amp;ecirc;ncia natural dos desenvolvedores, s&amp;atilde;o detalhes que n&amp;atilde;o s&amp;atilde;o necess&amp;aacute;rios at&amp;eacute; mais tarde e atrasam o in&amp;iacute;cio da implementa&amp;ccedil;&amp;atilde;o.&lt;/span&gt;&lt;/li&gt;
    &lt;li style=&quot;text-align: justify; color: rgb(0, 0, 0); font-size: 16px;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;&lt;strong&gt;Solu&amp;ccedil;&amp;atilde;o&lt;/strong&gt;&lt;/strong&gt; : Estabele&amp;ccedil;a uma maneira de trabalhar em que apenas detalhes suficientes (e nada mais) sejam adicionados &amp;agrave;s realiza&amp;ccedil;&amp;otilde;es de casos de uso para compreender completamente o impacto nos elementos de implementa&amp;ccedil;&amp;atilde;o.&lt;/span&gt;&lt;/li&gt;
&lt;/ul&gt;
&lt;h3 style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 1.3125em;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;u&gt;Paralisia de an&amp;aacute;lise&lt;/u&gt;&lt;/span&gt;&lt;/h3&gt;
&lt;ul&gt;
    &lt;li style=&quot;text-align: justify; color: rgb(0, 0, 0); font-size: 16px;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&amp;Agrave;s vezes, uma equipe pode ficar obcecada com o conjunto perfeito de realiza&amp;ccedil;&amp;otilde;es de casos de uso ou tentando analisar todos os casos de uso ao mesmo tempo.&lt;/span&gt;&lt;/li&gt;
    &lt;li style=&quot;text-align: justify; color: rgb(0, 0, 0); font-size: 16px;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;&lt;strong&gt;Problema&lt;/strong&gt;&lt;/strong&gt; : As equipes perdem de vista seu objetivo mais importante, que &amp;eacute; produzir software funcional para suas partes interessadas. Em vez disso, distraem-se com os seus pr&amp;oacute;prios objetivos internos.&lt;/span&gt;&lt;/li&gt;
    &lt;li style=&quot;text-align: justify; color: rgb(0, 0, 0); font-size: 16px;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;&lt;strong&gt;Solu&amp;ccedil;&amp;atilde;o&lt;/strong&gt;&lt;/strong&gt; : Analise apenas as fatias de casos de uso no escopo ou planeje a an&amp;aacute;lise como uma tarefa imediatamente antes da implementa&amp;ccedil;&amp;atilde;o de uma fatia.&lt;/span&gt;&lt;/li&gt;
&lt;/ul&gt;
&lt;p style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 16px;&quot;&gt;_______________&lt;/p&gt;
&lt;p style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 16px;&quot;&gt;&lt;strong&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;u&gt;Refer&amp;ecirc;ncias de apoio&lt;/u&gt;&lt;/span&gt;&lt;/strong&gt;&lt;/p&gt;
&lt;p style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 16px;&quot;&gt;&lt;sup&gt;&lt;sup style=&quot;font-size: smaller;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;1&lt;/span&gt;&lt;/sup&gt;&lt;/sup&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&amp;nbsp;The CRC Card Book, by David Bellin and Susan Suchman Simone, Addison-Wesley, chapter 3-4.&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 16px;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;sup&gt;&lt;sup style=&quot;font-size: smaller;&quot;&gt;2&lt;/sup&gt;&lt;/sup&gt; The Unified Software Development Process, by Ivar Jacobson, Grady Booch and James Rumbaugh, Addison Wesley Longman, chapter 8-9.&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 16px;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;sup&gt;&lt;sup style=&quot;font-size: smaller;&quot;&gt;3&lt;/sup&gt;&lt;/sup&gt;&amp;nbsp;&lt;/span&gt;&lt;u&gt;&lt;a href=&quot;http://www.extremeprogramming.org/rules/crccards.html&quot; target=&quot;_blank&quot; style=&quot;color: rgb(75, 110, 198);&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;www.extremeprogramming.org/rules/crccards.html&lt;/span&gt;&lt;/a&gt;&lt;/u&gt;&lt;/p&gt;</untitled-ontology-3:infAdicionais>
        <untitled-ontology-3:nome>&lt;p&gt;Analisar uma parte do caso de uso&lt;/p&gt;</untitled-ontology-3:nome>
