        <untitled-ontology-3:eProgredidoPor rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#AcompanharManterRastreabilidadeRequisitos"/>
        <untitled-ontology-3:eProgredidoPor rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#PlanejarRastreabilidadeRequisitos"/>
        <untitled-ontology-3:eProgredidoPor rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#RealizarRastreabilidadeRequisitos"/>
        <untitled-ontology-3:possui rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#DefinidoIA"/>
        <untitled-ontology-3:possui rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#EmDesenvolvimentoIA"/>
        <untitled-ontology-3:possui rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#GerenciadoIA"/>
        <untitled-ontology-3:Icone>&lt;p&gt;Icone Alpha&lt;/p&gt;</untitled-ontology-3:Icone>
        <untitled-ontology-3:descricao>&lt;ul&gt;
    &lt;li style=&quot;font-size: 12px;&quot;&gt;
        &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Um item ou artefato a ser rastreado pode ser caracterizado como um requisito de neg&amp;oacute;cio, requisito funcional, requisito n&amp;atilde;o funcional, caso de teste, caso de uso, prot&amp;oacute;tipo&amp;hellip;.&lt;/span&gt;&lt;/p&gt;
    &lt;/li&gt;
    &lt;li style=&quot;font-size: 12px;&quot;&gt;
        &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Os itens podem estar no mesmo n&amp;iacute;vel do ciclo de desenvolvimento de software ou em n&amp;iacute;veis diferentes, dependendo da especificidade da rastreabilidade e do tipo de relacionamento entre eles.&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;
    &lt;/li&gt;
&lt;/ul&gt;</untitled-ontology-3:descricao>
        <untitled-ontology-3:nome>&lt;p&gt;Item ou artefato a ser rastreado&lt;/p&gt;</untitled-ontology-3:nome>
        <untitled-ontology-3:sequencia rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">7</untitled-ontology-3:sequencia>
    </owl:NamedIndividual>
    


