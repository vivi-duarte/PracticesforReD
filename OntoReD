    <!-- http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#PreparacaoER -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#PreparacaoER">
        <rdf:type rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#PassosElementosPrática"/>
        <untitled-ontology-3:estaContidoEm rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#PadraoOrientacoesRegistroER"/>
        <untitled-ontology-3:descricao>&lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&apos;font-size: 12px;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;&lt;strong&gt;A prepara&amp;ccedil;&amp;atilde;o para elicita&amp;ccedil;&amp;atilde;o consiste em garantir que todos os recursos necess&amp;aacute;rios estejam organizados e preservados para a sua realiza&amp;ccedil;&amp;atilde;o e &amp;eacute; fundamental para garantir um bom resultado na elicita&amp;ccedil;&amp;atilde;o.&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&apos;font-size: 12px;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;&lt;strong&gt;Entende-se como recursos:&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;
&lt;ul&gt;
    &lt;li style=&apos;list-style-type: disc;font-size: 12px;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;
        &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Agenda das pessoas envolvidas&lt;/span&gt;&lt;/p&gt;
    &lt;/li&gt;
    &lt;li style=&apos;list-style-type: disc;font-size: 12px;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;
        &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Disponibilidade de salas&lt;/span&gt;&lt;/p&gt;
    &lt;/li&gt;
    &lt;li style=&apos;list-style-type: disc;font-size: 12px;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;
        &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Planejamento de viagens, quando necess&amp;aacute;rio&lt;/span&gt;&lt;/p&gt;
    &lt;/li&gt;
    &lt;li style=&apos;list-style-type: disc;font-size: 12px;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;
        &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Quest&amp;otilde;es log&amp;iacute;sticas de modo geral&lt;/span&gt;&lt;/p&gt;
    &lt;/li&gt;
&lt;/ul&gt;
&lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Tamb&amp;eacute;m, &amp;eacute; o momento de selecionar as t&amp;eacute;cnicas que ser&amp;atilde;o utilizadas durante a elicita&amp;ccedil;&amp;atilde;o&lt;/span&gt;&lt;/strong&gt;&lt;/span&gt;&lt;span style=&apos;font-size: 12px;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;. A escolha das t&amp;eacute;cnicas pode ser influenciada pelo: dom&amp;iacute;nio do neg&amp;oacute;cio, cultura empresarial, habilidades da equipe e recursos dispon&amp;iacute;veis.&amp;nbsp;&lt;/span&gt;&lt;/p&gt;
&lt;ul&gt;
    &lt;li style=&apos;list-style-type: disc;font-size: 12px;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;
        &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;N&amp;atilde;o existe a melhor t&amp;eacute;cnica, mas sim, aquela que se adapta melhor em determinada necessidade ou projeto.&amp;nbsp;&lt;/span&gt;&lt;/p&gt;
    &lt;/li&gt;
    &lt;li style=&apos;list-style-type: disc;font-size: 12px;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;
        &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Normalmente, na elicita&amp;ccedil;&amp;atilde;o se utiliza mais de uma t&amp;eacute;cnica.&lt;/span&gt;&lt;/p&gt;
    &lt;/li&gt;
    &lt;li style=&apos;list-style-type: disc;font-size: 12px;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;
        &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Importante que o analista tenha familiaridade com v&amp;aacute;rias t&amp;eacute;cnicas para que seja usada a mais adequada conforme o projeto ou perfil dos stakeholders.&lt;/span&gt;&lt;/p&gt;
        &lt;ul style=&quot;font-size: initial;&quot;&gt;
            &lt;li style=&apos;list-style-type: circle;font-size: 12px;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;
                &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;&lt;strong&gt;Para auxiliar na escolha da t&amp;eacute;cnica, recomenda-se consultar as orienta&amp;ccedil;&amp;otilde;es do guia&amp;nbsp;facetado&amp;nbsp;&lt;/strong&gt;&lt;/span&gt;&lt;span style=&apos;color: rgb(74, 74, 74);background-color: rgb(255, 255, 255);font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;&lt;strong&gt;de&lt;/strong&gt;&lt;/span&gt;&lt;span style=&quot;color: rgb(74, 74, 74);background-color: rgb(255, 255, 255);font-family: Roboto, sans-serif;&quot;&gt;&lt;strong&gt;&amp;nbsp;&lt;/strong&gt;&lt;/span&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;&lt;strong&gt;t&amp;eacute;cnicas de elicita&amp;ccedil;&amp;atilde;o de requisitos:&lt;/strong&gt;&lt;/span&gt;&lt;span style=&apos;color: rgb(74, 74, 74);background-color: rgb(255, 255, 255);font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;&lt;strong&gt;&amp;nbsp;&lt;/strong&gt;&lt;/span&gt;&lt;strong&gt;&lt;a href=&quot;https://retraining.inf.ufsc.br/guia/app&quot;&gt;&lt;span style=&apos;color: rgb(11, 87, 208);background-color: rgb(255, 255, 255);font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;https://retraining.inf.ufsc.br/guia/app&lt;/span&gt;&lt;/a&gt;&lt;/strong&gt;&lt;span style=&apos;color: rgb(74, 74, 74);background-color: rgb(255, 255, 255);font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;&lt;strong&gt;&amp;nbsp;&lt;/strong&gt;&lt;/span&gt;&lt;span style=&apos;font-size: 8px;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;&amp;nbsp;(&lt;/span&gt;&lt;span style=&apos;color: rgb(74, 74, 74);background-color: rgb(255, 255, 255);font-size: 8px;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;IGN&amp;Aacute;CIO; BENITTI 2020)&lt;/span&gt;&lt;span style=&apos;color: rgb(74, 74, 74);background-color: rgb(255, 255, 255);font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;.&lt;/span&gt;&lt;/p&gt;
            &lt;/li&gt;
        &lt;/ul&gt;
    &lt;/li&gt;
&lt;/ul&gt;
&lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&apos;font-size: 12px;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Para qualquer necessidade de informa&amp;ccedil;&amp;atilde;o deve-se manter na prepara&amp;ccedil;&amp;atilde;o para a elicita&amp;ccedil;&amp;atilde;o:&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Lista de stakeholders com pap&amp;eacute;is e responsabilidades definidas&lt;/span&gt;&lt;/strong&gt;&lt;/span&gt;&lt;span style=&apos;font-size: 12px;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;&amp;nbsp;(com quem o analista ir&amp;aacute; interagir).&lt;/span&gt;&lt;/p&gt;</untitled-ontology-3:descricao>
        <untitled-ontology-3:nome>&lt;p style=&quot;text-align: center;&quot;&gt;&lt;strong&gt;&lt;span style=&apos;font-size: 14px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Prepara&amp;ccedil;&amp;atilde;o para elicita&amp;ccedil;&amp;atilde;o de requisitos&lt;/span&gt;&lt;/strong&gt;&lt;/p&gt;</untitled-ontology-3:nome>
        <untitled-ontology-3:sequenciaAtividadeUC rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">1</untitled-ontology-3:sequenciaAtividadeUC>
