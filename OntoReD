    <!-- http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#CriteriosAceitacao -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#CriteriosAceitacao">
        <rdf:type rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#Alpha"/>
        <untitled-ontology-3:possui rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#DefinidoCA"/>
        <untitled-ontology-3:possui rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#ImplementadoCA"/>
        <untitled-ontology-3:possui rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#RegistradoCA"/>
        <untitled-ontology-3:Icone>&lt;p&gt;Icone Alpha&lt;/p&gt;</untitled-ontology-3:Icone>
        <untitled-ontology-3:descricao>&lt;p style=&quot;text-align: center;&quot;&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;&lt;strong&gt;Apresenta&amp;ccedil;&amp;atilde;o&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&apos;font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Crit&amp;eacute;rios de aceita&amp;ccedil;&amp;atilde;o consistem em uma parte importante de cada user story que cont&amp;eacute;m uma lista de restri&amp;ccedil;&amp;otilde;es que devem ser atendidas para que o usu&amp;aacute;rio ou stakeholders (Product Owner) aceitem a entrega e definam como &amp;ldquo;done&amp;rdquo; ao final do seu desenvolvimento&amp;nbsp;&lt;/span&gt;&lt;span style=&apos;font-size: 9px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;(Audy 2015)&lt;/span&gt;&lt;span style=&apos;font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;.&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot;text-align: center;&quot;&gt;&lt;span style=&apos;font-size: 14px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;&lt;strong&gt;Crit&amp;eacute;rios de aceita&amp;ccedil;&amp;atilde;o:&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&apos;font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Caracterizam-se como registros sobre regras de neg&amp;oacute;cio ou requisitos de qualidade pertencentes a user story, ou seja, um checklist de requisitos que a user story, em particular, deve atender&amp;nbsp;&lt;/span&gt;&lt;span style=&apos;font-size: 9px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;(Duarte 2021)&lt;/span&gt;&lt;span style=&apos;font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;.&lt;/span&gt;&lt;/p&gt;
&lt;p&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Para descrever os crit&amp;eacute;rios de aceita&amp;ccedil;&amp;atilde;o sugere-se o seguinte padr&amp;atilde;o&lt;/span&gt;&lt;/strong&gt;&lt;/span&gt;&lt;span style=&apos;font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;&amp;nbsp;&lt;/span&gt;&lt;span style=&apos;font-size: 9px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;(Audy 2015)&lt;/span&gt;&lt;span style=&apos;font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;:&lt;/span&gt;&lt;/p&gt;
&lt;ul&gt;
    &lt;li style=&apos;list-style-type: disc; font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;
        &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Dado que&lt;/span&gt;&lt;/strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;&amp;nbsp;&amp;lt;contexto inicial proposto&amp;gt;&lt;/span&gt;&lt;/p&gt;
    &lt;/li&gt;
    &lt;li style=&apos;list-style-type: disc; font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;
        &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Quando&amp;nbsp;&lt;/span&gt;&lt;/strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;&amp;lt;evento ocorrido&amp;gt;&lt;/span&gt;&lt;/p&gt;
    &lt;/li&gt;
    &lt;li style=&apos;list-style-type: disc; font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;
        &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Ent&amp;atilde;o&amp;nbsp;&lt;/span&gt;&lt;/strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;&amp;lt;resultado esperado&amp;gt;&lt;/span&gt;&lt;/p&gt;
    &lt;/li&gt;
&lt;/ul&gt;
&lt;p&gt;&lt;strong&gt;&lt;span style=&quot;font-size:10pt;font-family:&apos;Times New Roman&apos;,serif;&quot;&gt;Exemplos de crit&amp;eacute;rios de aceita&amp;ccedil;&amp;atilde;o HU - Realizar Check-in no sistema da companhia a&amp;eacute;rea&amp;nbsp;&lt;/span&gt;&lt;/strong&gt;&lt;span style=&apos;font-size: 9px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;(Reinher &amp;nbsp;2020)&lt;/span&gt;&lt;span style=&quot;font-size:8pt;font-family:&apos;Times New Roman&apos;,serif;&quot;&gt;:&lt;/span&gt;&lt;/p&gt;
&lt;ul&gt;
    &lt;li style=&quot;list-style-type:disc;font-size:10pt;font-family:&apos;Times New Roman&apos;,serif;&quot;&gt;
        &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;font-size:10pt;font-family:&apos;Times New Roman&apos;,serif;&quot;&gt;Apresentar os assentos para o usu&amp;aacute;rio selecionar o desejado, destacando e permitindo a sele&amp;ccedil;&amp;atilde;o dos assentos dispon&amp;iacute;veis;&lt;/span&gt;&lt;/p&gt;
    &lt;/li&gt;
    &lt;li style=&quot;list-style-type:disc;font-size:10pt;font-family:&apos;Times New Roman&apos;,serif;&quot;&gt;
        &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;font-size:10pt;font-family:&apos;Times New Roman&apos;,serif;&quot;&gt;Sinalizar os assentos especiais, permitindo a aquisi&amp;ccedil;&amp;atilde;o no momento do check-in.&lt;/span&gt;&lt;/p&gt;
    &lt;/li&gt;
    &lt;li style=&quot;list-style-type:disc;font-size:10pt;font-family:&apos;Times New Roman&apos;,serif;&quot;&gt;
        &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;font-size:10pt;font-family:&apos;Times New Roman&apos;,serif;&quot;&gt;Apresentar a possibilidade da compra de bagagem extra, no momento do check-in.&lt;/span&gt;&lt;/p&gt;
    &lt;/li&gt;
&lt;/ul&gt;</untitled-ontology-3:descricao>
        <untitled-ontology-3:nome>&lt;p&gt;Crit&amp;eacute;rios de aceita&amp;ccedil;&amp;atilde;o&lt;/p&gt;</untitled-ontology-3:nome>
        <untitled-ontology-3:sequencia rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">11</untitled-ontology-3:sequencia>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#CriteriosEvidenciasQualidadeDescritosDC -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#CriteriosEvidenciasQualidadeDescritosDC">
        <rdf:type rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#PassosElementosPrática"/>
        <untitled-ontology-3:atendidoPor rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#ConcordarDefinicaoConcluidoPB"/>
        <untitled-ontology-3:estaContidoEm rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#DefinicaoConcluidoPB"/>
        <untitled-ontology-3:descricao>&lt;ul&gt;
    &lt;li style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;text-align: left; color: rgb(0, 0, 0); font-size: 14px;&quot;&gt;A base objetiva sobre a qual cada condi&amp;ccedil;&amp;atilde;o de qualidade ser&amp;aacute; assegurada, avaliada e evidenciada est&amp;aacute; totalmente definida.&lt;/span&gt;&lt;/li&gt;
&lt;/ul&gt;
&lt;p style=&quot;text-align: center;&quot;&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;&lt;strong&gt;Espera-se que:&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;
&lt;ul&gt;
    &lt;li style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;&lt;span style=&quot;text-align: left;color: rgb(0, 0, 0);font-size: 14.4px;&quot;&gt;Os tipos de verifica&amp;ccedil;&amp;atilde;o/teste de garantia de qualidade que precisam ser conclu&amp;iacute;dos s&amp;atilde;o descritos.&lt;/span&gt;&lt;/span&gt;&lt;/li&gt;
    &lt;li style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;&lt;span&gt;&lt;span style=&quot;text-align: left;color: rgb(0, 0, 0);font-size: 14.4px;&quot;&gt;Fica claro como os resultados dos testes ser&amp;atilde;o avaliados, analisados e evidenciados.&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/li&gt;
&lt;/ul&gt;</untitled-ontology-3:descricao>
        <untitled-ontology-3:nome>&lt;p style=&quot;text-align: center;&quot;&gt;&lt;strong&gt;Crit&amp;eacute;rios e Evid&amp;ecirc;ncias de Qualidade Descritos&lt;/strong&gt;&lt;/p&gt;</untitled-ontology-3:nome>
