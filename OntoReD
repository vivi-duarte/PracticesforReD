    <!-- http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#EstruturaHUCompreendida -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#EstruturaHUCompreendida">
        <rdf:type rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#EstadoAlpha"/>
        <untitled-ontology-3:avancadoPor rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#DividirCasosUso"/>
        <untitled-ontology-3:avancadoPor rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#PrepararParteCasoUso"/>
        <untitled-ontology-3:eSequenciaDe rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#CasoUso"/>
        <untitled-ontology-3:Icone>&lt;p&gt;Icone Estado Alpha&lt;/p&gt;</untitled-ontology-3:Icone>
        <untitled-ontology-3:descricao>&lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;text-align: left; color: rgb(0, 0, 0); font-size: 12px;&quot;&gt;&lt;strong&gt;A estrutura da narrativa do caso de uso foi compreendida o suficiente para que a equipe comece a trabalhar identificando e implementando as primeiras fatias do caso de uso.&lt;/strong&gt;&lt;/span&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;&lt;strong&gt;&amp;nbsp;&lt;/strong&gt;&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;
&lt;ul&gt;
    &lt;li style=&quot;text-align: justify; font-size: 12px;&quot;&gt;&lt;strong&gt;Fluxo b&amp;aacute;sico determinado: &lt;/strong&gt;As principais etapas do fluxo b&amp;aacute;sico foram determinadas.&lt;/li&gt;
    &lt;li style=&quot;text-align: justify; font-size: 12px;&quot;&gt;&lt;strong&gt;Natureza de outros fluxos determinada:&lt;/strong&gt; Foram determinados o tipo e a natureza dos demais fluxos que comp&amp;otilde;em o caso de uso.&amp;nbsp;&lt;/li&gt;
    &lt;li style=&quot;text-align: justify; font-size: 12px;&quot;&gt;&lt;strong&gt;O in&amp;iacute;cio e o fim s&amp;atilde;o claros:&lt;/strong&gt; O in&amp;iacute;cio e o fim do caso de uso s&amp;atilde;o claros.&amp;nbsp;&lt;/li&gt;
    &lt;li style=&quot;text-align: justify; font-size: 12px;&quot;&gt;&lt;strong&gt;As fatias mais importantes s&amp;atilde;o &amp;apos;Preparadas&amp;apos;:&lt;/strong&gt; As fatias de caso de uso mais importantes (aquelas que cobrem o comportamento essencial do caso de uso) est&amp;atilde;o no estado Preparado.&lt;/li&gt;
&lt;/ul&gt;</untitled-ontology-3:descricao>
        <untitled-ontology-3:nome>&lt;p style=&quot;text-align: justify;&quot;&gt;&lt;b&gt;&lt;span style=&quot;text-align: left; color: rgb(0, 0, 0); font-size: 14px;&quot;&gt;&lt;strong&gt;Estrutura da hist&amp;oacute;ria compreendida&lt;/strong&gt;&lt;/span&gt;&lt;/b&gt;&lt;/p&gt;</untitled-ontology-3:nome>
        <untitled-ontology-3:sequencia rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">2</untitled-ontology-3:sequencia>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#Estruturada -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#Estruturada">
        <rdf:type rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#PassosElementosPrática"/>
        <untitled-ontology-3:atendidoPor rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#EcontrarAtoreseUC"/>
        <untitled-ontology-3:estaContidoEm rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#ModeloCasoUso"/>
        <untitled-ontology-3:descricao>&lt;ul&gt;
    &lt;li style=&quot;font-size: 12px; text-align: justify;&quot;&gt;O modelo de casos de uso geralmente cont&amp;eacute;m informa&amp;ccedil;&amp;otilde;es redundantes, como sequ&amp;ecirc;ncias comuns ou padr&amp;otilde;es de intera&amp;ccedil;&amp;atilde;o. Estruturar o modelo de casos de uso &amp;eacute; a maneira de lidar com essas redund&amp;acirc;ncias.&lt;/li&gt;
    &lt;li style=&quot;font-size: 12px; text-align: justify;&quot;&gt;Para sistemas grandes e complexos, especialmente aqueles que s&amp;atilde;o usados para fornecer funcionalidades semelhantes em muitos contextos diferentes, a estrutura&amp;ccedil;&amp;atilde;o do modelo de casos de uso pode ajudar na compreens&amp;atilde;o, eliminar desperd&amp;iacute;cios e ajudar a encontrar elementos reutiliz&amp;aacute;veis.&lt;/li&gt;
&lt;/ul&gt;
&lt;p style=&quot;text-align: center;&quot;&gt;&lt;strong&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Espera-se que:&lt;/span&gt;&lt;/strong&gt;&lt;/p&gt;
&lt;ul&gt;
    &lt;li style=&quot;font-size: 12px; text-align: justify;&quot;&gt;Os relacionamentos de &amp;apos;include&amp;apos; e &amp;apos;generaliza&amp;ccedil;&amp;atilde;o&amp;apos; s&amp;atilde;o usados para melhorar a clareza do modelo de casos de uso. A pergunta a ser feita ao estruturar o modelo &amp;eacute;: &amp;apos;Como podemos tornar o modelo de casos de uso mais compreens&amp;iacute;vel para as partes interessadas, eliminando os pontos em comum?&amp;apos;&amp;nbsp;&lt;/li&gt;
    &lt;li style=&quot;font-size: 12px; text-align: justify;&quot;&gt;Os relacionamentos &amp;apos;extend&amp;apos; s&amp;atilde;o usados para expressar o comportamento de extens&amp;atilde;o, ou seja, fluxos de eventos adicionados a casos de uso completos e existentes.&amp;nbsp;&lt;/li&gt;
    &lt;li style=&quot;font-size: 12px; text-align: justify;&quot;&gt;O modelo de casos de uso ainda &amp;eacute; compreens&amp;iacute;vel para uma parte interessada novata. Isto pode ser alcan&amp;ccedil;ado atrav&amp;eacute;s de uma refatora&amp;ccedil;&amp;atilde;o cautelosa e da explica&amp;ccedil;&amp;atilde;o do modelo de casos de uso em um ou mais diagramas.&lt;/li&gt;
&lt;/ul&gt;</untitled-ontology-3:descricao>
        <untitled-ontology-3:nome>&lt;p style=&quot;text-align: center;&quot;&gt;&lt;strong&gt;Estruturada&lt;/strong&gt;&lt;/p&gt;</untitled-ontology-3:nome>
        <untitled-ontology-3:sequencia rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">3</untitled-ontology-3:sequencia>
    </owl:NamedIndividual>
    


