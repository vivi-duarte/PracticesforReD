    <!-- http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#FonteInformacaoER -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#FonteInformacaoER">
        <rdf:type rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#Alpha"/>
        <untitled-ontology-3:eProgredidoPor rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#ConfirmacaoInformacaoER"/>
        <untitled-ontology-3:eProgredidoPor rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#PreparacaoTER"/>
        <untitled-ontology-3:eProgredidoPor rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#RealizacaoER"/>
        <untitled-ontology-3:eProgredidoPor rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#RegistroInformacaoER"/>
        <untitled-ontology-3:possui rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#ExecutadoFonteInformacaoER"/>
        <untitled-ontology-3:possui rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#FinalizadoFonteInformacaoER"/>
        <untitled-ontology-3:possui rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#PlanejadoFonteInformacaoER"/>
        <untitled-ontology-3:Icone>&lt;p&gt;Icone Alpha&lt;/p&gt;</untitled-ontology-3:Icone>
        <untitled-ontology-3:descricao>&lt;p&gt;&lt;span style=&apos;font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;&amp;Eacute; importante que a origem dos requisitos esteja clara e que os potenciais stakeholders sejam envolvidos logo no in&amp;iacute;cio do processo de elicita&amp;ccedil;&amp;atilde;o de requisitos.&lt;/span&gt;&lt;/p&gt;
&lt;p&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Pohl e Rupp (2015) definem tr&amp;ecirc;s tipos de fontes de informa&amp;ccedil;&amp;atilde;o:&lt;/span&gt;&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;
&lt;ul&gt;
    &lt;li style=&apos;list-style-type: disc; font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;
        &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Stakeholders:&amp;nbsp;&lt;/span&gt;&lt;/strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;s&amp;atilde;o pessoas ou organiza&amp;ccedil;&amp;otilde;es que interferem (direta ou indiretamente) nos requisitos do sistema. Como exemplos, destacam-se os usu&amp;aacute;rios, operadores do sistema, desenvolvedores, arquitetos, clientes, testadores.&lt;/span&gt;&lt;/p&gt;
    &lt;/li&gt;
    &lt;li style=&apos;list-style-type: disc; font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;
        &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Documentos:&lt;/span&gt;&lt;/strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;&amp;nbsp;mant&amp;eacute;m informa&amp;ccedil;&amp;otilde;es que podem conter requisitos, como, por exemplo, documentos legais ou regulat&amp;oacute;rios, normas, assim como documentos espec&amp;iacute;ficos do dom&amp;iacute;nio de neg&amp;oacute;cio ou da pr&amp;oacute;pria empresa, como documentos de requisitos ou documentos de erros em sistemas legados.&lt;/span&gt;&lt;/p&gt;
    &lt;/li&gt;
    &lt;li style=&apos;list-style-type: disc; font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;
        &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Sistemas em opera&amp;ccedil;&amp;atilde;o:&lt;/span&gt;&lt;/strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;&amp;nbsp;sistemas legados ou antecessores.&amp;nbsp;&lt;/span&gt;&lt;/p&gt;
    &lt;/li&gt;
&lt;/ul&gt;
&lt;p&gt;&lt;strong&gt;&lt;span style=&apos;font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;No m&amp;eacute;todo &amp;aacute;gil SCRUM, utiliza-se o papel do product owner (PO) ou seja, o dono do produto, que &amp;eacute; respons&amp;aacute;vel por gerenciar o product backlog. As principais atribui&amp;ccedil;&amp;otilde;es do PO concentram-se no gerenciamento e prioridades do product backlog e garantir a compreens&amp;atilde;o adequada de cada item do backlog por parte da equipe de desenvolvimento&lt;/span&gt;&lt;span style=&quot;font-size:10pt;font-family:&apos;Times New Roman&apos;,serif;&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;/strong&gt;&lt;span style=&quot;font-size:8pt;font-family:&apos;Times New Roman&apos;,serif;&quot;&gt;(&lt;span style=&quot;color:#0c343d;font-size:8pt;font-family:&apos;Times New Roman&apos;,serif;&quot;&gt;Reinher&amp;nbsp;&lt;/span&gt;2018)&lt;/span&gt;&lt;span style=&quot;font-size:10pt;font-family:&apos;Times New Roman&apos;,serif;&quot;&gt;.&lt;/span&gt;&lt;/p&gt;
&lt;p&gt;&lt;strong&gt;&lt;span style=&apos;font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Envolvimento dos stakeholders&lt;/span&gt;&lt;/strong&gt;&lt;span style=&apos;font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;font-size:8pt;font-family:&apos;Times New Roman&apos;,serif;&quot;&gt;(&lt;span style=&quot;font-size:8pt;font-family:&apos;Times New Roman&apos;,serif;&quot;&gt;Leffin-Gwell 2011 apud &lt;span style=&quot;color:#0c343d;font-size:8pt;font-family:&apos;Times New Roman&apos;,serif;&quot;&gt;Reinher&amp;nbsp;&lt;/span&gt;2018)&lt;/span&gt;&lt;/span&gt;&lt;span style=&quot;font-size:10pt;font-family:&apos;Times New Roman&apos;,serif;&quot;&gt;:&lt;/span&gt;&lt;/p&gt;
&lt;ul&gt;
    &lt;li style=&apos;list-style-type: disc; font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;
        &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Stakeholders que devem ser mantidos informados:&lt;/span&gt;&lt;/strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;&amp;nbsp;aqueles que precisam acompanhar o status do projeto e precisam ser mantidos atualizados e informados sobre as decis&amp;otilde;es, embora nem sempre tomem parte dessas decis&amp;otilde;es.&lt;/span&gt;&lt;/p&gt;
    &lt;/li&gt;
    &lt;li style=&apos;list-style-type: disc; font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;
        &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Stakeholders que devem ser consultados:&amp;nbsp;&lt;/span&gt;&lt;/strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;aqueles que devem ser envolvidos devido &amp;agrave;s &amp;aacute;reas de expertise, como ocorre com arquitetos, projetistas de interface, marketing e especialistas do dom&amp;iacute;nio. Devem ser inclu&amp;iacute;dos nas decis&amp;otilde;es contribuindo com a sua &amp;aacute;rea de expertise.&lt;/span&gt;&lt;/p&gt;
    &lt;/li&gt;
    &lt;li style=&apos;list-style-type: disc; font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;
        &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Stakeholders que ser&amp;atilde;o parceiros no desenvolvimento:&amp;nbsp;&lt;/span&gt;&lt;/strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;aqueles que devem ser envolvidos por serem partes do processo. Por exemplo, os product owners de outros projetos, outras equipes de desenvolvimento, analistas de neg&amp;oacute;cios ou requisitos e provedores de solu&amp;ccedil;&amp;otilde;es que interagem com o sistema.&lt;/span&gt;&lt;/p&gt;
    &lt;/li&gt;
    &lt;li style=&apos;list-style-type: disc; font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;
        &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Stakeholders que controlam os resultados:&amp;nbsp;&lt;/span&gt;&lt;/strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;aqueles que tomam as decis&amp;otilde;es sobre a solu&amp;ccedil;&amp;atilde;o desejada. Por exemplo, os executivos, gerentes de libera&amp;ccedil;&amp;atilde;o, usu&amp;aacute;rios-chave que v&amp;atilde;o utilizar a solu&amp;ccedil;&amp;atilde;o e business owners.&lt;/span&gt;&lt;/p&gt;
    &lt;/li&gt;
&lt;/ul&gt;
&lt;p&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Orienta&amp;ccedil;&amp;otilde;es para definir as &amp;nbsp;fontes de informa&amp;ccedil;&amp;atilde;o&lt;/span&gt;&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&apos;font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Para identificar quais s&amp;atilde;o as fontes de informa&amp;ccedil;&amp;atilde;o dos requisitos para determinado projeto, recomenda-se conversar com o respons&amp;aacute;vel pela aquisi&amp;ccedil;&amp;atilde;o do projeto para que ele determine as &amp;aacute;reas de neg&amp;oacute;cios que ter&amp;atilde;o alguma interface com o neg&amp;oacute;cio que est&amp;aacute; sendo tratado pelo software e identifique poss&amp;iacute;veis leis ou regulamenta&amp;ccedil;&amp;otilde;es que precisam ser atendidas.&amp;nbsp;&lt;/span&gt;&lt;/p&gt;
&lt;p&gt;&lt;span style=&apos;font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Recomenda&amp;ccedil;&amp;otilde;es de quest&amp;otilde;es para a identifica&amp;ccedil;&amp;atilde;o dos stakeholders&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;font-size:8pt;font-family:&apos;Times New Roman&apos;,serif;&quot;&gt;(Leffin-Gwell 2011 apud &lt;span style=&quot;color:#0c343d;font-size:8pt;font-family:&apos;Times New Roman&apos;,serif;&quot;&gt;Reinher&amp;nbsp;&lt;/span&gt;2018):&lt;/span&gt;&lt;span style=&quot;font-size:10pt;font-family:&apos;Times New Roman&apos;,serif;&quot;&gt;&amp;nbsp;&amp;nbsp;&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot;text-align: center;&quot;&gt;&lt;span style=&quot;color:#0c343d;font-size:8pt;font-family:&apos;Times New Roman&apos;,serif;&quot;&gt;Tabela &amp;nbsp;1: Quest&amp;otilde;es para identifica&amp;ccedil;&amp;atilde;o dos stakeholders&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot;text-align: center;&quot;&gt;&lt;span style=&quot;font-size:10pt;font-family:&apos;Times New Roman&apos;,serif;&quot;&gt;&lt;span style=&quot;border:none;&quot;&gt;&lt;img src=&quot;https://lh7-rt.googleusercontent.com/docsz/AD_4nXduITF_svr9ZizGf51HtAnXADeD0k697NLo-M2SySz6WKIScwZUn6mggi2F6qfQIgmpTOHpWm18byhQUGtMW_uSueFJk0qeqzdLwVwDAIGX5sHKwSUB3OqmAfTYSd5qq5h43DNuMkb0IKmjuzjThVYBtB-J?key=bWYZdeVOtJgVilXi-41QBQ&quot; width=&quot;395&quot; height=&quot;299&quot;&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot;text-align: center;&quot;&gt;&lt;span style=&quot;color:#0c343d;font-size:8pt;font-family:&apos;Times New Roman&apos;,serif;&quot;&gt;Fonte: Reinher, 2018&lt;/span&gt;&lt;/p&gt;</untitled-ontology-3:descricao>
        <untitled-ontology-3:nome>&lt;p&gt;Fontes de informa&amp;ccedil;&amp;atilde;o&lt;/p&gt;</untitled-ontology-3:nome>
        <untitled-ontology-3:sequencia rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">8</untitled-ontology-3:sequencia>
    </owl:NamedIndividual>
    


