    <!-- http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#GrafoRastreabilidade -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#GrafoRastreabilidade">
        <rdf:type rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#ProdutoTrabalhoPratica"/>
        <untitled-ontology-3:contem rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#EmExecucaoGR"/>
        <untitled-ontology-3:contem rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#PlanejadoGR"/>
        <untitled-ontology-3:contem rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#RealizadoGR"/>
        <untitled-ontology-3:eOrganizadoPor rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#ItemArtefatoRastreado"/>
        <untitled-ontology-3:eOrganizadoPor rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#RelacionamentoItensArtefatos"/>
        <untitled-ontology-3:eProduzidoPor rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#AcompanharManterRastreabilidadeRequisitos"/>
        <untitled-ontology-3:eProduzidoPor rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#PlanejarRastreabilidadeRequisitos"/>
        <untitled-ontology-3:eProduzidoPor rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#RealizarRastreabilidadeRequisitos"/>
        <untitled-ontology-3:Icone>&lt;p&gt;Icone Produto de Trabalho&lt;/p&gt;</untitled-ontology-3:Icone>
        <untitled-ontology-3:descricao>&lt;ul&gt;
    &lt;li style=&quot;text-align: justify;font-size: 12px;&quot;&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Representado por um gr&amp;aacute;fico no qual os n&amp;oacute;s representam artefatos (itens a serem rastreados) e as linhas do relacionamento entre eles.&lt;/span&gt;&lt;/li&gt;
    &lt;li style=&quot;text-align: justify;font-size: 12px;&quot;&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;A diferen&amp;ccedil;a entre artefatos e os tipos de rastreabilidade pode ser definida por meio da designa&amp;ccedil;&amp;atilde;o de diferentes atributos para os n&amp;oacute;s e linhas do grafo.&lt;/span&gt;&lt;/li&gt;
&lt;/ul&gt;
&lt;p style=&quot;text-align: center;&quot;&gt;&lt;span style=&apos;font-size: 12px;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;&lt;strong&gt;Apresenta&amp;ccedil;&amp;atilde;o&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;
&lt;ul&gt;
    &lt;li style=&quot;text-align: justify;font-size: 12px;&quot;&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;No grafo, um tipo de n&amp;oacute; deve ser definido para cada tipo de artefato de desenvolvimento. A letra &amp;ldquo;C&amp;rdquo; representa informa&amp;ccedil;&amp;otilde;es sobre o contexto do software; &amp;ldquo;Req-n&amp;rdquo; representa o requisito; e &amp;ldquo;Comp-n&amp;rdquo;, componentes.&amp;nbsp;&lt;/span&gt;&lt;/li&gt;
    &lt;li style=&quot;text-align: justify;font-size: 12px;&quot;&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Tamb&amp;eacute;m, s&amp;atilde;o definidas tr&amp;ecirc;s tipos de linhas que representam tr&amp;ecirc;s tipos de relacionamento:&amp;nbsp;&lt;/span&gt;&lt;strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;executado por&lt;/span&gt;&lt;/strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;;&amp;nbsp;&lt;/span&gt;&lt;strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;&amp;eacute; origem&lt;/span&gt;&lt;/strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;;&amp;nbsp;&lt;/span&gt;&lt;strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;refina&lt;/span&gt;&lt;/strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;.&lt;/span&gt;&lt;/li&gt;
&lt;/ul&gt;
&lt;p style=&quot;text-align: center;&quot;&gt;&lt;span style=&quot;font-size:8pt;font-family:&apos;Times New Roman&apos;,serif;&quot;&gt;Figura 1: Grafo de rastreabilidade de requisitos&lt;/span&gt;&lt;/p&gt;
