    <!-- http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#MetaEstabelecida -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#MetaEstabelecida">
        <rdf:type rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#EstadoAlpha"/>
        <untitled-ontology-3:avancadoPor rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#EcontrarAtoreseUC"/>
        <untitled-ontology-3:avancadoPor rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#InspecionarCasoUso"/>
        <untitled-ontology-3:eSequenciaDe rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#CasoUso"/>
        <untitled-ontology-3:Icone>&lt;p&gt;Icone Estado Alpha&lt;/p&gt;</untitled-ontology-3:Icone>
        <untitled-ontology-3:descricao>&lt;p&gt;&lt;strong&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Em primeiro lugar, a meta do caso de uso deve ser estabelecida.&amp;nbsp;&lt;/span&gt;&lt;/strong&gt;&lt;/p&gt;
&lt;ul&gt;
    &lt;li style=&quot;text-align: justify; font-size: 12px;&quot;&gt;&lt;strong&gt;Atores prim&amp;aacute;rios nomeados:&amp;nbsp;&lt;/strong&gt;Os principais atores do caso de uso foram identificados e nomeados.&amp;nbsp;&lt;/li&gt;
    &lt;li style=&quot;text-align: justify; font-size: 12px;&quot;&gt;&lt;strong&gt;Objetivo e valor claramente descritos:&lt;/strong&gt; O objetivo do caso de uso e o valor que ele fornecer&amp;aacute; foram claramente descritos (ou seja, a narrativa do caso de uso &amp;eacute; detalhada em Descrito Resumidamente).&amp;nbsp;&lt;/li&gt;
    &lt;li style=&quot;text-align: justify; font-size: 12px;&quot;&gt;&lt;strong&gt;As partes interessadas concordam com o objetivo:&amp;nbsp;&lt;/strong&gt;Todas as partes interessadas relevantes concordam com a meta que o caso de uso deve cumprir.&amp;nbsp;&lt;/li&gt;
    &lt;li style=&quot;text-align: justify; font-size: 12px;&quot;&gt;&lt;strong&gt;Dentro ou fora do escopo?:&lt;/strong&gt; Est&amp;aacute; claro se o caso de uso est&amp;aacute; dentro ou fora do escopo&amp;nbsp;&lt;/li&gt;
    &lt;li style=&quot;text-align: justify; font-size: 12px;&quot;&gt;&lt;strong&gt;A narrativa do caso de uso &amp;eacute; brevemente descrita:&lt;/strong&gt; A narrativa do caso de uso &amp;eacute; descrita resumidamente ou al&amp;eacute;m.&lt;/li&gt;
&lt;/ul&gt;</untitled-ontology-3:descricao>
        <untitled-ontology-3:nome>&lt;p&gt;&lt;strong&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;Meta Estabelecida&lt;/span&gt;&lt;/strong&gt;&lt;/p&gt;</untitled-ontology-3:nome>
        <untitled-ontology-3:sequencia rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">1</untitled-ontology-3:sequencia>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#ModeloCasoUso -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#ModeloCasoUso">
        <rdf:type rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#ProdutoTrabalhoPratica"/>
        <untitled-ontology-3:contem rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#Estruturada"/>
        <untitled-ontology-3:contem rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#LimiteValorEstabelecido"/>
        <untitled-ontology-3:contem rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#ValorEstabelecido"/>
        <untitled-ontology-3:eOrganizadoPor rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#CasoUso"/>
        <untitled-ontology-3:eProduzidoPor rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#EcontrarAtoreseUC"/>
        <untitled-ontology-3:Icone>&lt;p&gt;Icone Produto de Trabalho&lt;/p&gt;</untitled-ontology-3:Icone>
        <untitled-ontology-3:apresentacao>&lt;p&gt;Pr&amp;aacute;tica &amp;aacute;gil que utiliza casos de uso para capturar um conjunto de requisitos e impulsionar o desenvolvimento incremental de um sistema para atend&amp;ecirc;-los.&lt;/p&gt;
&lt;p&gt;&lt;br&gt;&lt;/p&gt;</untitled-ontology-3:apresentacao>
        <untitled-ontology-3:descricao>&lt;p style=&quot;text-align: center;&quot;&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;&lt;strong&gt;Modelo de caso de uso&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;
&lt;ul&gt;
    &lt;li style=&quot;font-size: 12px; text-align: justify;&quot;&gt;Um modelo que captura e visualiza todas as formas &amp;uacute;teis de usar um sistema.&lt;/li&gt;
    &lt;li style=&quot;font-size: 12px; text-align: justify;&quot;&gt;Permite que as equipes cheguem a um acordo sobre as funcionalidades e caracter&amp;iacute;sticas necess&amp;aacute;rias de um sistema.&lt;/li&gt;
    &lt;li style=&quot;font-size: 12px; text-align: justify;&quot;&gt;Estabelece claramente os limites e o escopo do sistema, fornecendo uma imagem completa de seus atores (estando fora do sistema) e casos de uso (estando dentro do sistema).&lt;/li&gt;
    &lt;li style=&quot;font-size: 12px; text-align: justify;&quot;&gt;Fornece o contexto para a elabora&amp;ccedil;&amp;atilde;o dos casos de uso individuais.&lt;/li&gt;
    &lt;li style=&quot;font-size: 12px; text-align: justify;&quot;&gt;Permite o gerenciamento &amp;aacute;gil de requisitos.&lt;/li&gt;
&lt;/ul&gt;
&lt;p style=&quot;text-align: center;&quot;&gt;&lt;strong&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Apresenta&amp;ccedil;&amp;atilde;o&lt;/span&gt;&lt;/strong&gt;&lt;/p&gt;
&lt;ul&gt;
    &lt;li style=&quot;text-align: justify; font-weight: bold;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;O objetivo de um modelo de casos de uso &amp;eacute; capturar todas as maneiras &amp;uacute;teis de usar um sistema em um formato acess&amp;iacute;vel que capture os requisitos de um sistema e possa ser usado para orientar seu desenvolvimento e testes.&lt;/strong&gt;&lt;/span&gt;&lt;/li&gt;
    &lt;li style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Um modelo de casos de uso &amp;eacute; composto principalmente por um conjunto de atores e casos de uso juntamente com seus relacionamentos e diagramas que ilustram esses elementos. Os modelos de casos de uso podem ser capturados de muitas maneiras diferentes, como um Wiki, um quadro branco ou flipchart, um conjunto de slides do Microsoft PowerPoint, um documento do Microsoft Word ou uma ferramenta de modelagem.&lt;/span&gt;&lt;br&gt;&lt;/span&gt;&lt;/li&gt;
    &lt;li style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Considerando que seu modelo de caso de uso mostre claramente o valor que as partes interessadas receber&amp;atilde;o de seu sistema novo ou atualizado, ele estar&amp;aacute; fazendo seu trabalho. Deve-se ter cuidado ao adicionar detalhes ao modelo. Somente avance para o limite do sistema estabelecido ou estruturado se esses n&amp;iacute;veis de detalhe claramente agregarem valor e ajudarem voc&amp;ecirc; a entregar o novo sistema com mais efici&amp;ecirc;ncia.&lt;/span&gt;&lt;br&gt;&lt;/span&gt;&lt;/li&gt;
&lt;/ul&gt;
&lt;p style=&quot;text-align: center;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;Informa&amp;ccedil;&amp;otilde;es adicionais&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;
&lt;h2 style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 1.75em;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;u&gt;Conte&amp;uacute;do essencial&lt;/u&gt;&lt;/span&gt;&lt;/h2&gt;
&lt;ul&gt;
    &lt;li style=&quot;font-size: 12px; text-align: justify;&quot;&gt;1..N Defini&amp;ccedil;&amp;otilde;es de ator: Um ator &amp;eacute; algu&amp;eacute;m ou algo fora do sistema que interage com o sistema em uma fun&amp;ccedil;&amp;atilde;o espec&amp;iacute;fica. Os atores s&amp;atilde;o usados para: a) Estabelecer os limites do sistema e b) Permitir a identifica&amp;ccedil;&amp;atilde;o dos casos de uso que fornecem valor (para os atores)&lt;/li&gt;
    &lt;li style=&quot;font-size: 12px; text-align: justify;&quot;&gt;1..N Defini&amp;ccedil;&amp;otilde;es de casos de uso: Um caso de uso s&amp;atilde;o todas as maneiras de usar um sistema para atingir um objetivo espec&amp;iacute;fico para um usu&amp;aacute;rio espec&amp;iacute;fico.&amp;nbsp;Consulte tamb&amp;eacute;m a diretriz narrativa de casos de uso.&lt;/li&gt;
    &lt;li style=&quot;font-size: 12px; text-align: justify;&quot;&gt;1..N Associa&amp;ccedil;&amp;otilde;es: Associa&amp;ccedil;&amp;otilde;es e relacionamentos entre atores e casos de uso que denotam intera&amp;ccedil;&amp;atilde;o (frequentemente chamadas de associa&amp;ccedil;&amp;otilde;es de comunica&amp;ccedil;&amp;atilde;o).&lt;/li&gt;
    &lt;li style=&quot;font-size: 12px; text-align: justify;&quot;&gt;1 Explica&amp;ccedil;&amp;atilde;o do Modelo: Texto e ilustra&amp;ccedil;&amp;otilde;es explicando o modelo.&lt;/li&gt;
&lt;/ul&gt;
&lt;h2 style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 1.75em;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;&lt;u&gt;Conte&amp;uacute;do adicional&lt;/u&gt;&lt;/strong&gt;&lt;/span&gt;&lt;/h2&gt;
&lt;ul&gt;
    &lt;li style=&quot;font-size: 12px; text-align: justify;&quot;&gt;1..N Diagramas de Casos de Uso: Ilustra&amp;ccedil;&amp;otilde;es de atores, casos de uso e seus relacionamentos.&lt;/li&gt;
    &lt;li style=&quot;font-size: 12px; text-align: justify;&quot;&gt;1..N Pacotes de Casos de Uso: Pacotes de casos de uso e atores usados para organizar o modelo.&lt;/li&gt;
    &lt;li style=&quot;font-size: 12px; text-align: justify;&quot;&gt;1..N Relacionamentos de Casos de Uso: Um relacionamento de &amp;apos;inclus&amp;atilde;o&amp;apos; entre casos de uso expressa a reutiliza&amp;ccedil;&amp;atilde;o de descri&amp;ccedil;&amp;otilde;es de comportamento comuns.&amp;nbsp;Um relacionamento &amp;apos;estende&amp;apos; expressa como um caso de uso adiciona comportamento a outro.&amp;nbsp;A generaliza&amp;ccedil;&amp;atilde;o entre casos de uso expressa que a sequ&amp;ecirc;ncia de um caso de uso &amp;eacute; reutilizada por outro&lt;/li&gt;
    &lt;li style=&quot;font-size: 12px; text-align: justify;&quot;&gt;1..N Relacionamentos entre atores: A generaliza&amp;ccedil;&amp;atilde;o entre atores expressa que um ator pode desempenhar o papel do outro ator.&lt;/li&gt;
&lt;/ul&gt;
&lt;p&gt;&lt;br&gt;&lt;/p&gt;</untitled-ontology-3:descricao>
        <untitled-ontology-3:nome>&lt;p&gt;Modelo de caso de uso&lt;/p&gt;</untitled-ontology-3:nome>
        <untitled-ontology-3:referenciaRE>&lt;p style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 16px;&quot;&gt;&lt;sup&gt;&lt;sup style=&quot;font-size: smaller;&quot;&gt;1&lt;/sup&gt;&lt;/sup&gt; Use Case Modeling, de Kurt Bittner e Ian Spence, Addison-Wesley Professional, cap&amp;iacute;tulos 4-5.&lt;/p&gt;

&lt;p style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 16px;&quot;&gt;&lt;sup&gt;&lt;sup style=&quot;font-size: smaller;&quot;&gt;2&lt;/sup&gt;&lt;/sup&gt; Use Case Patterns and Blueprints, por Gunnar &amp;Ouml;vergaard e Karin Palmkvist, Addison Wesley, cap&amp;iacute;tulos 16-44.&lt;/p&gt;</untitled-ontology-3:referenciaRE>
        <untitled-ontology-3:sequencia rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">1</untitled-ontology-3:sequencia>
    </owl:NamedIndividual>
    


