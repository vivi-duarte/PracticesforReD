        <untitled-ontology-3:atendidoPor rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#PrepararParteCasoUso"/>
        <untitled-ontology-3:descricao>&lt;ul&gt;
    &lt;li style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&amp;Agrave;s vezes &amp;eacute; necess&amp;aacute;rio esclarecer as responsabilidades do sistema e dos seus intervenientes durante a realiza&amp;ccedil;&amp;atilde;o do caso de uso. Um esbo&amp;ccedil;o com marcadores captura essas responsabilidades, mas n&amp;atilde;o define claramente quais partes do caso de uso s&amp;atilde;o assumidas pelo sistema e quais s&amp;atilde;o assumidas pelo(s) ator(es).&lt;/span&gt;&lt;/li&gt;
    &lt;li style=&quot;text-align: justify; color: rgb(0, 0, 0); font-size: 17.6px;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Neste n&amp;iacute;vel de detalhe a narrativa torna-se uma descri&amp;ccedil;&amp;atilde;o do di&amp;aacute;logo entre o sistema e os seus atores. &amp;Eacute; particularmente &amp;uacute;til ao estabelecer a arquitetura de um novo sistema ou ao tentar estabelecer uma nova experi&amp;ecirc;ncia de usu&amp;aacute;rio.&lt;/span&gt;&lt;/li&gt;
&lt;/ul&gt;
&lt;p style=&quot;text-align: center;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;Espera-se que:&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;
&lt;ul&gt;
    &lt;li style=&quot;text-align: justify; font-size: 12px;&quot;&gt;O caso de uso foi expresso como um di&amp;aacute;logo entre os atores e o sistema.&amp;nbsp;&lt;/li&gt;
    &lt;li style=&quot;text-align: justify; color: rgb(0, 0, 0); font-size: 12px;&quot;&gt;Existem etapas individuais para cada ator e responsabilidade do sistema.&lt;/li&gt;
&lt;/ul&gt;</untitled-ontology-3:descricao>
        <untitled-ontology-3:nome>&lt;p style=&quot;text-align: center;&quot;&gt;&lt;strong&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;Esbo&amp;ccedil;o essencial&lt;/span&gt;&lt;/strong&gt;&lt;/p&gt;</untitled-ontology-3:nome>
        <untitled-ontology-3:sequencia rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">3</untitled-ontology-3:sequencia>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#EsbocoMarcadores -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#EsbocoMarcadores">
