    <!-- http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#AbordagemQuantificacao -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#AbordagemQuantificacao">
        <rdf:type rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#PraticaDivida"/>
        <untitled-ontology-3:eParteDe rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#Identificacao"/>
        <untitled-ontology-3:implementadaPor rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#InformarConsequenciaManterDivida"/>
        <untitled-ontology-3:implementadaPor rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#QuantificarJuroDivida"/>
        <untitled-ontology-3:implementadaPor rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#QuantificarTamanhoDivida"/>
        <untitled-ontology-3:implementadaPor rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#StatusCrescimentoDivida"/>
        <untitled-ontology-3:classificacaoPratica>Geral</untitled-ontology-3:classificacaoPratica>
        <untitled-ontology-3:descricao>&lt;p&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Consiste em quantificar a d&amp;iacute;vida t&amp;eacute;cnica e seu interesse t&amp;eacute;cnico, mas para isso seria necess&amp;aacute;rio responder quest&amp;otilde;es sobre investimentos, como:&lt;/span&gt;&lt;/p&gt;
&lt;ul&gt;
    &lt;li&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Qual o tamanho da &lt;span style=&quot;font-size: 12px;&quot;&gt;d&amp;iacute;vida t&amp;eacute;cnica&lt;/span&gt;?&amp;nbsp;&lt;/span&gt;&lt;/li&gt;
    &lt;li&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Quanto de juros estou pagando pela &lt;span style=&quot;font-size: 12px;&quot;&gt;d&amp;iacute;vida t&amp;eacute;cnica&lt;/span&gt;?&amp;nbsp;&lt;/span&gt;&lt;/li&gt;
    &lt;li&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;A d&amp;iacute;vida est&amp;aacute; crescendo? E qu&amp;atilde;o r&amp;aacute;pido?&amp;nbsp;&lt;/span&gt;&lt;/li&gt;
    &lt;li&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Qual ser&amp;aacute; a consequ&amp;ecirc;ncia de manter esta &lt;span style=&quot;font-size: 12px;&quot;&gt;d&amp;iacute;vida t&amp;eacute;cnica&amp;nbsp;&lt;/span&gt;para manuten&amp;ccedil;&amp;atilde;o futura?&lt;/span&gt;&lt;/li&gt;
&lt;/ul&gt;
&lt;p&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;A &lt;span style=&quot;font-size: 12px;&quot;&gt;d&amp;iacute;vida t&amp;eacute;cnica&amp;nbsp;&lt;/span&gt;pode ser quantificada considerando a rela&amp;ccedil;&amp;atilde;o entre as necessidades do usu&amp;aacute;rio j&amp;aacute; eliciadas e todas as poss&amp;iacute;veis necessidades do usu&amp;aacute;rio, inclusive as negligenciadas.&lt;/span&gt;&lt;/p&gt;</untitled-ontology-3:descricao>
        <untitled-ontology-3:nome>&lt;p style=&quot;text-align: center;&quot;&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;&lt;strong&gt;Abordagem de quantifica&amp;ccedil;&amp;atilde;o&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;</untitled-ontology-3:nome>
    </owl:NamedIndividual>
    


