    <!-- http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#RequisitosSistema -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#RequisitosSistema">
        <rdf:type rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#Alpha"/>
        <untitled-ontology-3:possui rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#CompletoRS"/>
        <untitled-ontology-3:possui rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#ImplantadoRS"/>
        <untitled-ontology-3:possui rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#ImplementadoRS"/>
        <untitled-ontology-3:possui rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#TestadoRS"/>
        <untitled-ontology-3:possui rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#ValidadoRS"/>
        <untitled-ontology-3:possui rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#ViavelRS"/>
        <untitled-ontology-3:Icone>&lt;p&gt;Icone Alpha&lt;/p&gt;</untitled-ontology-3:Icone>
        <untitled-ontology-3:descricao>&lt;p style=&quot;text-align: center;&quot;&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;&lt;strong&gt;Apresenta&amp;ccedil;&amp;atilde;o&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot;text-align: justify;&quot;&gt;&lt;strong&gt;&lt;span style=&apos;background-color: rgb(255, 255, 255); font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Os requisitos de sistema s&amp;atilde;o descri&amp;ccedil;&amp;otilde;es mais detalhadas das fun&amp;ccedil;&amp;otilde;es, dos servi&amp;ccedil;os e das restri&amp;ccedil;&amp;otilde;es operacionais do sistema de software.&amp;nbsp;&lt;/span&gt;&lt;/strong&gt;&lt;/p&gt;
&lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&apos;background-color: rgb(255, 255, 255); font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;O documento de requisitos de sistema (especifica&amp;ccedil;&amp;atilde;o funcional) deve definir exatamente o que deve ser implementado. Eles podem ser usados como parte do contrato para a implementa&amp;ccedil;&amp;atilde;o do sistema e deve, portanto, ser uma especifica&amp;ccedil;&amp;atilde;o completa e detalhada de todo o sistema.&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;&lt;span style=&apos;background-color: rgb(255, 255, 255); font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Idealmente, os requisitos do sistema simplesmente descrevem o comportamento externo do sistema e suas restri&amp;ccedil;&amp;otilde;es operacionais.&lt;/span&gt;&lt;/strong&gt;&lt;/span&gt;&lt;span style=&apos;background-color: rgb(255, 255, 255); font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;&amp;nbsp;Eles n&amp;atilde;o devem se preocupar com como o sistema deve ser projetado ou implementado.&amp;nbsp;&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot;text-align: center;&quot;&gt;&lt;strong&gt;&lt;span style=&apos;color: rgb(12, 52, 61); background-color: rgb(255, 255, 255); font-size: 14px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Os requisitos de sistema podem ser classificados em&lt;/span&gt;&lt;span style=&apos;color: rgb(12, 52, 61); background-color: rgb(255, 255, 255); font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;&amp;nbsp;&lt;/span&gt;&lt;/strong&gt;&lt;span style=&apos;background-color: rgb(255, 255, 255); font-size: 9px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;(Sommerville 2018)&lt;/span&gt;&lt;strong&gt;&lt;span style=&apos;color: rgb(12, 52, 61); background-color: rgb(255, 255, 255); font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;:&lt;/span&gt;&lt;/strong&gt;&lt;/p&gt;
&lt;ul&gt;
    &lt;li style=&apos;list-style-type: disc; color: rgb(12, 52, 61); font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;
        &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;strong&gt;&lt;span style=&apos;color: rgb(12, 52, 61); background-color: rgb(255, 255, 255); font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Requisitos funcionais:&lt;/span&gt;&lt;/strong&gt;&lt;span style=&apos;color: rgb(12, 52, 61); background-color: rgb(255, 255, 255); font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;&amp;nbsp;S&amp;atilde;o declara&amp;ccedil;&amp;otilde;es de servi&amp;ccedil;os que o sistema deve fornecer, como o sistema deve reagir a entradas espec&amp;iacute;ficas..&amp;nbsp;&lt;/span&gt;&lt;/p&gt;
        &lt;ul style=&quot;font-size: initial;&quot;&gt;
            &lt;li style=&apos;list-style-type: circle; color: rgb(12, 52, 61); font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;
                &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&apos;color: rgb(12, 52, 61); background-color: rgb(255, 255, 255); font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Exemplos de requisitos funcionais:&lt;/span&gt;&lt;/p&gt;
                &lt;ul style=&quot;font-size: initial;&quot;&gt;
                    &lt;li style=&apos;list-style-type: square; color: rgb(12, 52, 61); font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;
                        &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&apos;color: rgb(12, 52, 61); background-color: rgb(255, 255, 255); font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Uma secret&amp;aacute;ria deve fazer uma busca na lista de consultas de todas as cl&amp;iacute;nicas.&lt;/span&gt;&lt;/p&gt;
                    &lt;/li&gt;
                    &lt;li style=&apos;list-style-type: square; color: rgb(12, 52, 61); font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;
                        &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&apos;color: rgb(12, 52, 61); background-color: rgb(255, 255, 255); font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;O sistema deve gerar para a secret&amp;aacute;ria, a cada dia e para cada cl&amp;iacute;nica, uma lista de pacientes que devem comparecer &amp;agrave;s consultas naquele dia.&lt;/span&gt;&lt;/p&gt;
                    &lt;/li&gt;
                &lt;/ul&gt;
            &lt;/li&gt;
        &lt;/ul&gt;
    &lt;/li&gt;
    &lt;li style=&apos;list-style-type: disc; color: rgb(12, 52, 61); font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;
        &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;strong&gt;&lt;span style=&apos;color: rgb(12, 52, 61); background-color: rgb(255, 255, 255); font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Requisitos n&amp;atilde;o funcionais ou de qualidade:&lt;/span&gt;&lt;/strong&gt;&lt;span style=&apos;color: rgb(12, 52, 61); background-color: rgb(255, 255, 255); font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;&amp;nbsp;S&amp;atilde;o restri&amp;ccedil;&amp;otilde;es aos servi&amp;ccedil;os ou fun&amp;ccedil;&amp;otilde;es oferecidos pelo sistema.&amp;nbsp;&lt;/span&gt;&lt;/p&gt;
        &lt;ul style=&quot;font-size: initial;&quot;&gt;
            &lt;li style=&apos;list-style-type: circle; color: rgb(12, 52, 61); font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;
                &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&apos;color: rgb(12, 52, 61); background-color: rgb(255, 255, 255); font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Eles incluem restri&amp;ccedil;&amp;otilde;es de tempo, restri&amp;ccedil;&amp;otilde;es ao processo de desenvolvimento e restri&amp;ccedil;&amp;otilde;es impostas por padr&amp;otilde;es.&amp;nbsp;&lt;/span&gt;&lt;/p&gt;
            &lt;/li&gt;
            &lt;li style=&apos;list-style-type: circle; color: rgb(12, 52, 61); font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;
                &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&apos;color: rgb(12, 52, 61); background-color: rgb(255, 255, 255); font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Requisitos n&amp;atilde;o funcionais geralmente se aplicam ao sistema como um todo, em vez de recursos ou servi&amp;ccedil;os individuais do sistema.&lt;/span&gt;&lt;/p&gt;
            &lt;/li&gt;
            &lt;li style=&apos;list-style-type: circle; color: rgb(12, 52, 61); font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;
                &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;strong&gt;&lt;span style=&apos;color: rgb(12, 52, 61); background-color: rgb(255, 255, 255); font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Os requisitos n&amp;atilde;o funcionais ou de qualidade podem ser classificados conforme a taxonomia sugerida em&amp;nbsp;&lt;/span&gt;&lt;/strong&gt;&lt;a href=&quot;https://retraining.inf.ufsc.br/taxonomiaRNF/&quot;&gt;&lt;strong&gt;&lt;u&gt;&lt;span style=&apos;color: rgb(11, 87, 208); background-color: rgb(255, 255, 255); font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;https://retraining.inf.ufsc.br/taxonomiaRNF/.&lt;/span&gt;&lt;/u&gt;&lt;/strong&gt;&lt;/a&gt;&lt;/p&gt;
            &lt;/li&gt;
        &lt;/ul&gt;
    &lt;/li&gt;
&lt;/ul&gt;</untitled-ontology-3:descricao>
        <untitled-ontology-3:nome>&lt;p&gt;Requisitos de sistema&lt;/p&gt;</untitled-ontology-3:nome>
        <untitled-ontology-3:sequencia rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">10</untitled-ontology-3:sequencia>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#RequisitosUsuario -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#RequisitosUsuario">
        <rdf:type rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#Alpha"/>
        <untitled-ontology-3:possui rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#Completo"/>
        <untitled-ontology-3:possui rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#Implantado"/>
        <untitled-ontology-3:possui rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#ImplementadoRU"/>
        <untitled-ontology-3:possui rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#Testado"/>
        <untitled-ontology-3:possui rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#Validado"/>
        <untitled-ontology-3:possui rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#Viavel"/>
        <untitled-ontology-3:Icone>&lt;p&gt;Icone Alpha&lt;/p&gt;</untitled-ontology-3:Icone>
        <untitled-ontology-3:descricao>&lt;p dir=&quot;ltr&quot; style=&quot;line-height: 1.38; text-indent: 36pt; text-align: center; margin-top: 0pt; margin-bottom: 0pt;&quot;&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;&lt;strong&gt;Apresenta&amp;ccedil;&amp;atilde;o&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;
&lt;p dir=&quot;ltr&quot; style=&quot;line-height:1.38;text-indent: 36pt;text-align: justify;margin-top:0pt;margin-bottom:0pt;&quot;&gt;&lt;span style=&apos;font-size: 12px; font-family: &quot;Times New Roman&quot;, serif; color: rgb(0, 0, 0); background-color: transparent; font-weight: 400; font-style: normal; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap;&apos;&gt;Os requisitos de usu&amp;aacute;rio s&amp;atilde;o declara&amp;ccedil;&amp;otilde;es descritas sob a perspectiva do usu&amp;aacute;rio, em linguagem natural adicionadas a diagramas, dos servi&amp;ccedil;os que se espera que o sistema ofere&amp;ccedil;a aos seus usu&amp;aacute;rios e das limita&amp;ccedil;&amp;otilde;es sob as quais ele pode operar. &amp;nbsp;&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot;text-align: center;&quot;&gt;&lt;span style=&quot;font-size:10pt;font-family:&apos;Times New Roman&apos;,serif;&quot;&gt;&lt;span style=&quot;border:none;&quot;&gt;&lt;img src=&quot;https://lh7-rt.googleusercontent.com/docsz/AD_4nXeMWh3TOMnO4oo_D8yw5SEdr3hGLDyw0An3XvlbDcUyagQbGbRj4-sRljsk51SY-IF2oTFCCWaUjMhpzrUD58DwWwOtl42IoPALdD2WyBwGunQhZ-thdiVaqyfh6zyktVhNzMLdJWJYenT49XYSoSGatPqE?key=bWYZdeVOtJgVilXi-41QBQ&quot; width=&quot;305&quot; height=&quot;59&quot;&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot;text-align: center;&quot;&gt;&lt;span style=&quot;background-color:#ffffff;font-size:8pt;font-family:&apos;Times New Roman&apos;,serif;&quot;&gt;Fonte: Sommerville, 2018&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot;text-align: justify;&quot;&gt;&lt;br&gt;&lt;/p&gt;
&lt;p style=&quot;text-align: center;&quot;&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;&lt;strong&gt;Os requisitos de usu&amp;aacute;rio:&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;
&lt;ul&gt;
    &lt;li style=&quot;text-align: justify; font-size: 12px;&quot;&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Podem variar de declara&amp;ccedil;&amp;otilde;es abrangentes das caracter&amp;iacute;sticas necess&amp;aacute;rias do sistema at&amp;eacute; descri&amp;ccedil;&amp;otilde;es detalhadas da sua funcionalidade.&lt;/span&gt;&lt;/li&gt;
    &lt;li style=&apos;list-style-type: disc; font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;
        &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Para elicit&amp;aacute;-los e registr&amp;aacute;-los, sugere-se o uso de hist&amp;oacute;rias de usu&amp;aacute;rio (HU) ou user story que caracterizam-se como unidades pass&amp;iacute;veis de serem desenvolvidas e entregues, com foco no valor do neg&amp;oacute;cio, utilizadas para documentar as funcionalidades&amp;nbsp;&lt;span style=&quot;font-size: 9px;&quot;&gt;(Audy 2015)&lt;/span&gt;.&amp;nbsp;A partir desses registros deve ser poss&amp;iacute;vel extrair os requisitos de sistemas. O registro deve ser suficientemente compreens&amp;iacute;vel pelos usu&amp;aacute;rios do sistema que n&amp;atilde;o possuem conhecimento t&amp;eacute;cnico detalhado.&lt;/span&gt;&lt;/p&gt;
    &lt;/li&gt;
    &lt;li style=&apos;list-style-type: disc; font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;
        &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;As HUs devem ser escritas conforme a perspectiva do usu&amp;aacute;rio ou stakeholders e sugere-se adotar o seguintes padr&amp;atilde;o: Como &amp;lt;&lt;/span&gt;&lt;strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;quem&lt;/span&gt;&lt;/strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;&amp;gt; eu [quero] [preciso] [gostaria] &amp;lt;&lt;/span&gt;&lt;strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;verbo&lt;/span&gt;&lt;/strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;&amp;gt; para &amp;lt;&lt;/span&gt;&lt;strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;por qu&amp;ecirc;?&lt;/span&gt;&lt;/strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;&amp;gt;&lt;/span&gt;&lt;/p&gt;
        &lt;ul style=&quot;font-size: initial;&quot;&gt;
            &lt;li style=&apos;list-style-type: circle; font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;
                &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Quem?&lt;/span&gt;&lt;/strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;&amp;nbsp;Cada user story deve, indicar quem &amp;eacute; o usu&amp;aacute;rio que ir&amp;aacute; utilizar e, por isto, a import&amp;acirc;ncia nesse requisito.&lt;/span&gt;&lt;/p&gt;
            &lt;/li&gt;
            &lt;li style=&apos;list-style-type: circle; font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;
                &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;O qu&amp;ecirc;?&amp;nbsp;&lt;/span&gt;&lt;/strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Exatamente o que o usu&amp;aacute;rio deseja, precisa ou gostaria que tal requisito lhe proporcionasse.&lt;/span&gt;&lt;/p&gt;
            &lt;/li&gt;
            &lt;li style=&apos;list-style-type: circle; font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;
                &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Por qu&amp;ecirc;?&lt;/span&gt;&lt;/strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;&amp;nbsp;Finalidade do requisito, ou seja, o valor que ser&amp;aacute; entregue por meio da user story.&lt;/span&gt;&lt;/p&gt;
            &lt;/li&gt;
        &lt;/ul&gt;
    &lt;/li&gt;
    &lt;li style=&apos;list-style-type: disc; font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;
        &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;A partir desses registros deve ser poss&amp;iacute;vel extrair os requisitos de sistemas. O registro deve ser suficientemente compreens&amp;iacute;vel pelos usu&amp;aacute;rios do sistema que n&amp;atilde;o possuem conhecimento t&amp;eacute;cnico detalhado.&lt;/span&gt;&lt;/p&gt;
    &lt;/li&gt;
&lt;/ul&gt;
&lt;p&gt;&lt;br&gt;&lt;/p&gt;
&lt;p&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Exemplo de um sistema de check-in de uma companhia a&amp;eacute;rea:&lt;/span&gt;&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot;text-align: justify;&quot;&gt;&lt;strong&gt;&lt;span style=&apos;font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;HU1:&lt;/span&gt;&lt;/strong&gt;&lt;span style=&apos;font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;em&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;&amp;ldquo;Como passageiro, eu quero fazer meu check-in via celular, para n&amp;atilde;o perder tempo na fila do aeroporto&amp;rdquo;&amp;nbsp;&lt;/span&gt;&lt;/em&gt;&lt;/span&gt;&lt;span style=&apos;font-size: 9px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;(Reinher 2020)&lt;/span&gt;&lt;span style=&apos;font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;.&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Recomenda&amp;ccedil;&amp;atilde;o para descri&amp;ccedil;&amp;atilde;o da HU&amp;nbsp;&lt;/span&gt;&lt;/strong&gt;&lt;/span&gt;&lt;span style=&apos;font-size: 9px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;(Duarte 2021)&lt;/span&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;:&amp;nbsp;&lt;/span&gt;&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;
&lt;ul&gt;
    &lt;li style=&apos;list-style-type: disc; font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;
        &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;A HU deve desconsiderar detalhes de implementa&amp;ccedil;&amp;atilde;o.&lt;/span&gt;&lt;/p&gt;
    &lt;/li&gt;
    &lt;li style=&apos;list-style-type: disc; font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;
        &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Focada no que o usu&amp;aacute;rio deseja fazer.&lt;/span&gt;&lt;/p&gt;
    &lt;/li&gt;
    &lt;li style=&apos;list-style-type: disc; font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;
        &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Descrita sob o ponto de vista do usu&amp;aacute;rio.&lt;/span&gt;&lt;/p&gt;
    &lt;/li&gt;
    &lt;li style=&apos;list-style-type: disc; font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;
        &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Curta e objetiva.&lt;/span&gt;&lt;/p&gt;
    &lt;/li&gt;
&lt;/ul&gt;
&lt;p&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;A HU tamb&amp;eacute;m deve ser&lt;/span&gt;&lt;/strong&gt;&lt;/span&gt;&lt;span style=&apos;font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;&amp;nbsp;&lt;/span&gt;&lt;/p&gt;
&lt;ul&gt;
    &lt;li style=&apos;list-style-type: disc; font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;
        &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Independente: devem ser independentes entre si.&lt;/span&gt;&lt;/p&gt;
    &lt;/li&gt;
    &lt;li style=&apos;list-style-type: disc; font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;
        &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Negoci&amp;aacute;vel: N&amp;atilde;o s&amp;atilde;o contratos, mas lembretes.&lt;/span&gt;&lt;/p&gt;
    &lt;/li&gt;
    &lt;li style=&apos;list-style-type: disc; font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;
        &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Estim&amp;aacute;vel: deve ser mensur&amp;aacute;vel.&lt;/span&gt;&lt;/p&gt;
    &lt;/li&gt;
    &lt;li style=&apos;list-style-type: disc; font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;
        &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Test&amp;aacute;vel: Poss&amp;iacute;vel de ser testada.&lt;/span&gt;&lt;/p&gt;
    &lt;/li&gt;
&lt;/ul&gt;</untitled-ontology-3:descricao>
        <untitled-ontology-3:nome>&lt;p&gt;Requisitos do usu&amp;aacute;rio&lt;/p&gt;</untitled-ontology-3:nome>
        <untitled-ontology-3:sequencia rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">9</untitled-ontology-3:sequencia>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#ResponsabilidadesAlocadas -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#ResponsabilidadesAlocadas">
        <rdf:type rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#PassosElementosPrática"/>
        <untitled-ontology-3:atendidoPor rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#AnalisarParteCasoUso"/>
        <untitled-ontology-3:descricao>&lt;ul&gt;
    &lt;li style=&quot;font-size: 12px; text-align: justify;&quot;&gt;Para permitir que a equipe atualize os elementos do sistema afetados em paralelo ou em suporte a diversas fatias de casos de uso, os desenvolvedores precisam compreender as responsabilidades dos elementos individuais. As responsabilidades fornecem uma defini&amp;ccedil;&amp;atilde;o de alto n&amp;iacute;vel do que cada elemento precisa fazer, armazenar e rastrear.&lt;/li&gt;
    &lt;li style=&quot;text-align: justify; color: rgb(0, 0, 0); font-size: 12px;&quot;&gt;Esse n&amp;iacute;vel de detalhe &amp;eacute; adequado para situa&amp;ccedil;&amp;otilde;es em que cada fatia do caso de uso aborda v&amp;aacute;rios elementos do sistema ou onde as fatias ser&amp;atilde;o desenvolvidas por v&amp;aacute;rios desenvolvedores trabalhando em paralelo. Deve tamb&amp;eacute;m ser adoptado quando a arquitetura do sistema &amp;eacute; imatura e as responsabilidades globais dos elementos do sistema ainda n&amp;atilde;o foram compreendidas.&lt;/li&gt;
&lt;/ul&gt;
&lt;p style=&quot;text-align: center;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;Espera-se que:&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;
&lt;ul&gt;
    &lt;li style=&quot;text-align: justify; font-size: 12px;&quot;&gt;As responsabilidades (dos fluxos relevantes) foram atribu&amp;iacute;das aos elementos da implementa&amp;ccedil;&amp;atilde;o.&lt;/li&gt;
    &lt;li style=&quot;text-align: justify; color: rgb(0, 0, 0); font-size: 12px;&quot;&gt;As responsabilidades dos elementos podem, juntas, realizar os fluxos de casos de uso em quest&amp;atilde;o.&amp;nbsp;&lt;/li&gt;
&lt;/ul&gt;</untitled-ontology-3:descricao>
        <untitled-ontology-3:nome>&lt;p style=&quot;text-align: center;&quot;&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;&lt;strong&gt;Responsabilidades alocadas&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;</untitled-ontology-3:nome>
        <untitled-ontology-3:sequencia rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">2</untitled-ontology-3:sequencia>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#Responsavel -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#Responsavel">
        <rdf:type rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#PraticaDivida"/>
        <untitled-ontology-3:eParteDe rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#Documentacao"/>
        <untitled-ontology-3:implementadaPor rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#InformarResponsavelPagamentoReD"/>
        <untitled-ontology-3:classificacaoPratica>Geral</untitled-ontology-3:classificacaoPratica>
        <untitled-ontology-3:nome>Responsável pela dívida de requisitos</untitled-ontology-3:nome>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#Retrabalho -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#Retrabalho">
        <rdf:type rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#ConsequenciaReD"/>
