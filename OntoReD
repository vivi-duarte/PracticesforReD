    <!-- http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#ConfirmacaoResultadosER -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#ConfirmacaoResultadosER">
        <rdf:type rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#PassosElementosPrática"/>
        <untitled-ontology-3:estaContidoEm rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#PadraoOrientacoesRegistroER"/>
        <untitled-ontology-3:descricao>&lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;font-size:10pt;font-family:&apos;Times New Roman&apos;,serif;&quot;&gt;As informa&amp;ccedil;&amp;otilde;es durante a elicita&amp;ccedil;&amp;atilde;o s&amp;oacute; podem ser confirmadas se houver um registro dessas informa&amp;ccedil;&amp;otilde;es, ou que enaltece a documenta&amp;ccedil;&amp;atilde;o como mecanismo fundamental durante o processo de elicita&amp;ccedil;&amp;atilde;o de requisitos. Caso n&amp;atilde;o sejam documentadas, existe um grande risco de perda dessas informa&amp;ccedil;&amp;otilde;es.&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot;text-align: justify;&quot;&gt;&lt;strong&gt;&lt;span style=&quot;font-size:10pt;font-family:&apos;Times New Roman&apos;,serif;&quot;&gt;Mesmo registrados, ainda podem ocorrer ru&amp;iacute;dos entre o relato da informa&amp;ccedil;&amp;atilde;o e sua compreens&amp;atilde;o por parte do analista, justificando a necessidade de confirma&amp;ccedil;&amp;atilde;o ou valida&amp;ccedil;&amp;atilde;o das informa&amp;ccedil;&amp;otilde;es junto &amp;agrave;s partes interessadas, ap&amp;oacute;s o momento da elicita&amp;ccedil;&amp;atilde;o&lt;/span&gt;&lt;/strong&gt;&lt;span style=&quot;font-size:10pt;font-family:&apos;Times New Roman&apos;,serif;&quot;&gt;&amp;nbsp;.&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;font-size:10pt;font-family:&apos;Times New Roman&apos;,serif;&quot;&gt;Importante seguir um protocolo de comunica&amp;ccedil;&amp;atilde;o para o momento da confirma&amp;ccedil;&amp;atilde;o, embora deva ser algo simples, sem burocracia.&amp;nbsp;&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;font-size:10pt;font-family:&apos;Times New Roman&apos;,serif;&quot;&gt;Um protocolo recomendado sobre como &amp;nbsp;&lt;/span&gt;&lt;strong&gt;&lt;span style=&quot;font-size:10pt;font-family:&apos;Times New Roman&apos;,serif;&quot;&gt;receber a informa&amp;ccedil;&amp;atilde;o, documentar e confirmar &amp;eacute; denominado &amp;ldquo;Protocolo do Garantidor&amp;rdquo;&lt;/span&gt;&lt;/strong&gt;&lt;span style=&quot;font-size:10pt;font-family:&apos;Times New Roman&apos;,serif;&quot;&gt;&amp;nbsp;, o qual &amp;eacute; simples e eficaz.&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot;text-align: center;&quot;&gt;&lt;span style=&quot;color:#0c343d;font-size:8pt;font-family:&apos;Times New Roman&apos;,serif;&quot;&gt;Figura 1: Protocolo da gar&amp;ccedil;a para filtrar falhas de comunica&amp;ccedil;&amp;atilde;o na elicita&amp;ccedil;&amp;atilde;o de requisitos&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot;text-align: center;&quot;&gt;&lt;span style=&quot;font-size:10pt;font-family:&apos;Times New Roman&apos;,serif;&quot;&gt;&lt;span style=&quot;border:none;&quot;&gt;&lt;img src=&quot;https://lh7-rt.googleusercontent.com/docsz/AD_4nXc6YPNSkXVVvnR2fa60zYUzoOMpJ-ZB3gt2izBS7KwhII7TfISbTiwHNqXr7imDnEYy5LW1U3ZFd2gh9ZUVmgnHPnwALJB0o0sS26II8vt01p0MRfW-AH4lKXzCnt6pKF23mgFXjof3ePZHPmt8YoHRGOI?key=bWYZdeVOtJgVilXi-41QBQ&quot; width=&quot;263&quot; height=&quot;123&quot;&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot;text-align: center;&quot;&gt;&lt;span style=&quot;color:#0c343d;font-size:8pt;font-family:&apos;Times New Roman&apos;,serif;&quot;&gt;Fonte: V&amp;aacute;zquez &amp;amp; Sim&amp;otilde;es, 2016&lt;/span&gt;&lt;/p&gt;</untitled-ontology-3:descricao>
        <untitled-ontology-3:nome>&lt;p style=&quot;text-align: center;&quot;&gt;&lt;strong&gt;&lt;span style=&apos;font-size: 14px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Confirma&amp;ccedil;&amp;atilde;o dos resultados da elicita&amp;ccedil;&amp;atilde;o de requisitos&lt;/span&gt;&lt;/strong&gt;&lt;/p&gt;</untitled-ontology-3:nome>
        <untitled-ontology-3:sequenciaAtividadeUC rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">3</untitled-ontology-3:sequenciaAtividadeUC>
    </owl:NamedIndividual>
    


