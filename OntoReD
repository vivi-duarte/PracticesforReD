&lt;ul&gt;
    &lt;li&gt;&lt;span class=&quot;fr-close-ul&quot;&gt;&lt;span style=&apos;font-size: 12px; font-family: &quot;Times New Roman&quot;, serif; color: rgb(0, 0, 0); background-color: transparent; font-weight: 700; font-style: normal; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap;&apos;&gt;Definir&lt;/span&gt;&lt;/span&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif; color: rgb(0, 0, 0); background-color: transparent; font-weight: 400; font-style: normal; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap; font-size: 12px;&apos;&gt;&amp;nbsp;&amp;nbsp; as informa&amp;ccedil;&amp;otilde;es iniciais do projeto.&lt;/span&gt;&lt;/li&gt;
    &lt;li&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif; color: rgb(0, 0, 0); background-color: transparent; font-weight: 400; font-style: normal; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap; font-size: 12px;&apos;&gt;Defini&amp;ccedil;&amp;atilde;o das fontes de informa&amp;ccedil;&amp;atilde;o.&lt;/span&gt;&lt;/li&gt;
    &lt;li&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif; color: rgb(0, 0, 0); background-color: transparent; font-weight: 400; font-style: normal; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap; font-size: 12px;&apos;&gt;Definir&lt;/span&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif; color: rgb(0, 0, 0); background-color: transparent; font-weight: 400; font-style: normal; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap; font-size: 12px;&apos;&gt;&amp;nbsp;uma t&amp;eacute;cnica de elicita&amp;ccedil;&amp;atilde;o de requisitos.&lt;/span&gt;&lt;/li&gt;
&lt;/ul&gt;</untitled-ontology-3:apresAtividade>
        <untitled-ontology-3:nome>&lt;p&gt;Preparar o treinamento de elicita&amp;ccedil;&amp;atilde;o de requisitos&lt;/p&gt;</untitled-ontology-3:nome>
