    <!-- http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#EsbocoEssencial -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#EsbocoEssencial">
        <rdf:type rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#PassosElementosPrática"/>
        <untitled-ontology-3:atendidoPor rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#DividirCasosUso"/>
