    <!-- http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#EntenderRequisitos -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#EntenderRequisitos">
        <rdf:type rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#EspacoAtividade"/>
        <untitled-ontology-3:contempla rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#AcompanharManterRastreabilidadeRequisitos"/>
        <untitled-ontology-3:contempla rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#ColetarConsolidarProblemas"/>
        <untitled-ontology-3:contempla rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#ConcordarDefinicaoConcluidoPB"/>
        <untitled-ontology-3:contempla rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#DefinirEscopoRevisao"/>
        <untitled-ontology-3:contempla rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#DetectarFalhasRevReq"/>
        <untitled-ontology-3:contempla rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#DividirCasosUso"/>
        <untitled-ontology-3:contempla rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#EcontrarAtoreseUC"/>
        <untitled-ontology-3:contempla rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#InspecionarCasoUso"/>
        <untitled-ontology-3:contempla rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#PrepararItemProductBacklog"/>
        <untitled-ontology-3:contempla rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#PrepararParteCasoUso"/>
        <untitled-ontology-3:contempla rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#RealizarRastreabilidadeRequisitos"/>
        <untitled-ontology-3:contempla rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#RefinarProductBacklog"/>
        <untitled-ontology-3:Icone>&lt;p&gt;Icone Espaco Atividade&lt;/p&gt;</untitled-ontology-3:Icone>
        <untitled-ontology-3:descricao>&lt;p style=&quot;text-align: left;&quot;&gt;&lt;strong&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;&amp;nbsp; &lt;strong&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Estabelecer um entendimento compartilhado sobre o que o sistema a ser produzido deve fazer. &amp;nbsp;&lt;/span&gt;&lt;/strong&gt;&lt;/span&gt;&lt;/strong&gt;&lt;/p&gt;
&lt;p&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&amp;nbsp;&lt;strong&gt;&amp;nbsp; Entender os requisitos para: &amp;nbsp;&lt;/strong&gt;&amp;nbsp;&lt;/span&gt;&lt;/p&gt;
&lt;ul&gt;
    &lt;li style=&quot;font-size: 12px;&quot;&gt;Definir o escopo do sistema.&lt;/li&gt;
    &lt;li style=&quot;font-size: 12px;&quot;&gt;Entender como o sistema ir&amp;aacute; gerar valor.&lt;/li&gt;
    &lt;li style=&quot;font-size: 12px;&quot;&gt;Combinar o que o sistema far&amp;aacute;.&lt;/li&gt;
    &lt;li style=&quot;font-size: 12px;&quot;&gt;Identificar as maneiras espec&amp;iacute;ficas de usar e testar o sistema.&lt;/li&gt;
    &lt;li style=&quot;font-size: 12px;&quot;&gt;Conduzir o desenvolvimento do sistema.&lt;/li&gt;
&lt;/ul&gt;
&lt;p&gt;&lt;strong&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;u&gt;Atividades dispon&amp;iacute;veis - Contempla:&lt;/u&gt;&lt;/span&gt;&lt;/strong&gt;&lt;/p&gt;
&lt;ul&gt;
    &lt;li style=&quot;text-align: justify;&quot;&gt;&lt;span style=&apos;font-size: 12px;;color: rgb(0, 0, 0); font-family: &quot;Times New Roman&quot;; font-size: 12px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; background-color: rgb(255, 255, 255); text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; display: inline !important; float: none;&apos;&gt;&lt;strong&gt;Encontrar atores e casos de uso:&amp;nbsp;&lt;/strong&gt;&lt;/span&gt;&lt;span style=&apos;color: rgb(0, 0, 0); font-family: &quot;Times New Roman&quot;; font-size: 12px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; background-color: rgb(255, 255, 255); text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; display: inline !important; float: none;;color: rgb(0, 0, 0); font-family: &quot;Times New Roman&quot;; font-size: 12px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; background-color: rgb(255, 255, 255); text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; display: inline !important; float: none;&apos;&gt;Concordar com os objetivos e o valor do sistema, identificando formas de us&amp;aacute;-lo e test&amp;aacute;-lo.&lt;/span&gt;&lt;/li&gt;
    &lt;li style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;Inspecionar e adaptar os casos de uso:&lt;/strong&gt;&amp;nbsp;&lt;/span&gt;&lt;span style=&apos;color: rgb(0, 0, 0); font-family: &quot;Times New Roman&quot;; font-size: 12px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; background-color: rgb(255, 255, 255); text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; display: inline !important; float: none;&apos;&gt;Lidar com as mudan&amp;ccedil;as e acompanhe o progresso ajustando o modelo de casos de uso, os casos de uso e as fatias de casos de uso.&lt;/span&gt;&lt;/li&gt;
    &lt;li style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;Preparar uma fatia de caso de uso:&amp;nbsp;&lt;/strong&gt;&lt;/span&gt;&lt;span style=&apos;color: rgb(0, 0, 0); font-family: &quot;Times New Roman&quot;; font-size: 12px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; background-color: rgb(255, 255, 255); text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; display: inline !important; float: none;&apos;&gt;Uma fatia de caso de uso &amp;eacute; preparada para desenvolvimento elaborando sua narrativa e casos de teste.&lt;/span&gt;&lt;/li&gt;
    &lt;li style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;Dividir os casos de uso:&amp;nbsp;&lt;/strong&gt;&lt;/span&gt;&lt;span style=&apos;color: rgb(0, 0, 0); font-family: &quot;Times New Roman&quot;; font-size: 12px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; background-color: rgb(255, 255, 255); text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; display: inline !important; float: none;&apos;&gt;Identificar fatias de casos de uso com base em casos de uso para auxiliar na implementa&amp;ccedil;&amp;atilde;o.&lt;/span&gt;&lt;/li&gt;
&lt;/ul&gt;
&lt;p style=&quot;font-size: 1em;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;u&gt;&lt;strong&gt;Refer&amp;ecirc;ncias:&lt;/strong&gt;&lt;/u&gt;&lt;/span&gt;&lt;/p&gt;
