        <untitled-ontology-3:eParteDe rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#Identificacao"/>
        <untitled-ontology-3:implementadaPor rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#CompromissoCliente"/>
        <untitled-ontology-3:implementadaPor rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#ComunicacaoPartesInteressadasStakeholders"/>
        <untitled-ontology-3:implementadaPor rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#ControlarNegociarREQ"/>
        <untitled-ontology-3:implementadaPor rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#DeclaracaoEscopoDefinido"/>
        <untitled-ontology-3:implementadaPor rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#RastreabilidadeREQ"/>
        <untitled-ontology-3:implementadaPor rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#RequisitosBemDefinidos"/>
        <untitled-ontology-3:classificacaoPratica>Geral</untitled-ontology-3:classificacaoPratica>
        <untitled-ontology-3:descricao>&lt;p&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Estudos prim&amp;aacute;rios relatam que prevenir a ocorr&amp;ecirc;ncia de uma d&amp;iacute;vida t&amp;eacute;cnica pode ser mais barato do que o seu pagamento.&amp;nbsp;&lt;/span&gt;&lt;/p&gt;
&lt;p&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;A&amp;ccedil;&amp;otilde;es preventivas apoiam profissionais e equipes de software na aplica&amp;ccedil;&amp;atilde;o de pr&amp;aacute;ticas aceit&amp;aacute;veis que minimizam sua ocorr&amp;ecirc;ncia.&amp;nbsp;&lt;/span&gt;&lt;/p&gt;
&lt;p&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;As a&amp;ccedil;&amp;otilde;es preventivas relacionadas &amp;agrave;s d&amp;iacute;vidas de requisitos s&amp;atilde;o: &lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;
&lt;ul&gt;
    &lt;li&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;C&lt;/span&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;ontrolar e negociar os requisitos de software;&amp;nbsp;&lt;/span&gt;&lt;/li&gt;
    &lt;li&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Requisitos bem definidos;&amp;nbsp;&lt;/span&gt;&lt;/li&gt;
    &lt;li&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Boa comunica&amp;ccedil;&amp;atilde;o entre as partes interessadas;&amp;nbsp;&lt;/span&gt;&lt;/li&gt;
    &lt;li&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Declara&amp;ccedil;&amp;atilde;o de escopo bem definida;&amp;nbsp;&lt;/span&gt;&lt;/li&gt;
    &lt;li&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Rastreamento de mudan&amp;ccedil;as de requisitos e;&lt;/span&gt;&lt;/li&gt;
    &lt;li&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Compromisso com o cliente.&lt;/span&gt;&lt;/li&gt;
&lt;/ul&gt;</untitled-ontology-3:descricao>
        <untitled-ontology-3:nome>Ações preventivas</untitled-ontology-3:nome>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#AcompanharManterRastreabilidadeRequisitos -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#AcompanharManterRastreabilidadeRequisitos">
