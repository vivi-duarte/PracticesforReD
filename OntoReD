    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#MapaPagamento">
        <rdf:type rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#PraticaDivida"/>
        <untitled-ontology-3:eParteDe rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#Identificacao"/>
        <untitled-ontology-3:implementadaPor rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#ManterMapaPagamentoDecisoesEliminacaoDivida"/>
