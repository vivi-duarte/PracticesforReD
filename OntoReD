        <untitled-ontology-3:descricao>&lt;div style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 16px;&quot;&gt;
    &lt;div style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 16px;&quot;&gt;
        &lt;p style=&quot;font-size: 1em; text-align: left;&quot;&gt;&lt;strong&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Construir um sistema implementando, testando e integrando um ou mais elementos do sistema.&amp;nbsp;&lt;/span&gt;&lt;/strong&gt;&lt;/p&gt;
        &lt;ul&gt;
            &lt;li style=&quot;font-size: 12px;&quot;&gt;Isso inclui corre&amp;ccedil;&amp;atilde;o de bugs e testes unit&amp;aacute;rios.&lt;/li&gt;
        &lt;/ul&gt;
    &lt;/div&gt;
    &lt;p style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 16px;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;Implementar o sistema para:&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;
    &lt;ul style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 16px;&quot;&gt;
        &lt;li style=&quot;font-size: 12px; text-align: justify;&quot;&gt;Criar um sistema funcional.&lt;/li&gt;
        &lt;li style=&quot;font-size: 12px; text-align: justify;&quot;&gt;Desenvolver, integrar e testar os elementos do sistema.&lt;/li&gt;
        &lt;li style=&quot;font-size: 12px; text-align: justify;&quot;&gt;Aumentar o n&amp;uacute;mero de requisitos implementados.&lt;/li&gt;
        &lt;li style=&quot;font-size: 12px; text-align: justify;&quot;&gt;Corrigir defeitos.&lt;/li&gt;
        &lt;li style=&quot;font-size: 12px; text-align: justify;&quot;&gt;Melhorar o sistema.&lt;/li&gt;
    &lt;/ul&gt;
&lt;/div&gt;
&lt;div style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 16px;&quot;&gt;
    &lt;p&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;Refer&amp;ecirc;ncias:&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;
    &lt;ul&gt;
        &lt;li style=&quot;font-size: 12px; color: rgb(0, 0, 0);&quot;&gt;Essence Standard (OMG), consulte &lt;u&gt;&lt;a href=&quot;http://www.omg.org/spec/Essence/1.1/&quot; target=&quot;_blank&quot; style=&quot;color: rgb(75, 110, 198);&quot;&gt;http://www.omg.org/spec/Essence/1.1/&lt;/a&gt;&lt;/u&gt;&lt;/li&gt;
        &lt;li style=&quot;font-size: 12px; color: rgb(0, 0, 0);&quot;&gt;A Ess&amp;ecirc;ncia da Engenharia de Software: Aplicando o Kernel SEMAT, por Ivar Jacobson, Pan-Wei Ng, Paul E. McMahon, Ian Spence e Svante Lidman, Addison-Wesley 2013.&lt;/li&gt;
    &lt;/ul&gt;
    &lt;p&gt;&lt;br&gt;&lt;/p&gt;
&lt;/div&gt;</untitled-ontology-3:descricao>
        <untitled-ontology-3:nome>&lt;p&gt;Implementar o sistema&lt;/p&gt;</untitled-ontology-3:nome>
        <untitled-ontology-3:sequenciaEspacoAtividade rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">3</untitled-ontology-3:sequenciaEspacoAtividade>
    </owl:NamedIndividual>
    


