&lt;ul&gt;
    &lt;li style=&quot;font-size: 12px;&quot;&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Erro caracteriza-se como um problema em produtos de trabalho voltado aos requisitos, como um documento de especifica&amp;ccedil;&amp;atilde;o de requisitos.&lt;/span&gt;&lt;/li&gt;
&lt;/ul&gt;
&lt;p style=&quot;text-align: center;&quot;&gt;&lt;strong&gt;&lt;span style=&apos;font-size: 14px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Um erro pode ser categorizado em&amp;nbsp;&lt;/span&gt;&lt;/strong&gt;&lt;span style=&apos;font-size: 10px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;(Geraldi; Oliveira 2017)&lt;/span&gt;&lt;strong&gt;&lt;span style=&apos;font-size: 10px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;:&lt;/span&gt;&lt;span style=&apos;font-size: 14px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;&amp;nbsp;&lt;/span&gt;&lt;/strong&gt;&lt;/p&gt;
&lt;ul&gt;
    &lt;li style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;De omiss&amp;atilde;o:&amp;nbsp;&lt;/span&gt;&lt;/strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;qualquer informa&amp;ccedil;&amp;atilde;o necess&amp;aacute;ria que tenha sido omitida.&lt;/span&gt;&lt;/li&gt;
    &lt;li style=&quot;font-size: 12px;&quot;&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;&lt;strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Fato Incorreto:&lt;/span&gt;&lt;/strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;&amp;nbsp;informa&amp;ccedil;&amp;atilde;o contradit&amp;oacute;ria com o conhecimento que se tem no dom&amp;iacute;nio de aplica&amp;ccedil;&amp;atilde;o.&lt;/span&gt;&lt;/span&gt;&lt;/li&gt;
    &lt;li style=&quot;font-size: 12px;&quot;&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;&lt;strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Inconsist&amp;ecirc;ncia:&lt;/span&gt;&lt;/strong&gt;&lt;/span&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif; font-size: 12px;&apos;&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;&amp;nbsp;informa&amp;ccedil;&amp;atilde;o que consta de forma repetitiva, escrita de forma diferente.&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/li&gt;
    &lt;li style=&quot;font-size: 12px;&quot;&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;&lt;strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Ambiguidade:&lt;/span&gt;&lt;/strong&gt;&lt;/span&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif; font-size: 12px;&apos;&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;&amp;nbsp;quando a informa&amp;ccedil;&amp;atilde;o pode levar a m&amp;uacute;ltiplas interpreta&amp;ccedil;&amp;otilde;es.&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/li&gt;
    &lt;li style=&quot;font-size: 12px;&quot;&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;&lt;strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Informa&amp;ccedil;&amp;atilde;o Estranha:&lt;/span&gt;&lt;/strong&gt;&lt;/span&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif; font-size: 12px;&apos;&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;&amp;nbsp;qualquer informa&amp;ccedil;&amp;atilde;o que, embora relacionada ao dom&amp;iacute;nio, n&amp;atilde;o &amp;eacute; necess&amp;aacute;ria para o sistema.&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/li&gt;
    &lt;li style=&quot;font-size: 12px;&quot;&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;&lt;strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Outros:&lt;/span&gt;&lt;/strong&gt;&lt;/span&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif; font-size: 12px;&apos;&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;&amp;nbsp;qualquer outro tipo de erro que n&amp;atilde;o se encaixe nas outras categorias. Exemplo: declara&amp;ccedil;&amp;otilde;es em se&amp;ccedil;&amp;otilde;es erradas.&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/li&gt;
