    <!-- http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#EcontrarAtoreseUC -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#EcontrarAtoreseUC">
        <rdf:type rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#AtividadeProdutoTrabalho"/>
        <untitled-ontology-3:produz rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#ModeloCasoUso"/>
        <untitled-ontology-3:produz rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#NarrativaCasoUso"/>
        <untitled-ontology-3:Icone>&lt;p&gt;Atividade Produto Trabalho&lt;/p&gt;</untitled-ontology-3:Icone>
        <untitled-ontology-3:Icone>&lt;p&gt;Icone Atividade Produto Trabalho&lt;/p&gt;</untitled-ontology-3:Icone>
        <untitled-ontology-3:abordagens>&lt;p style=&quot;text-align: center;&quot;&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;&lt;strong&gt;&lt;u&gt;Workshop de modelagem de casos de uso&lt;/u&gt;&lt;/strong&gt;&lt;/span&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/p&gt;
&lt;ul&gt;
    &lt;li style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Esta &amp;eacute; a abordagem recomendada.&lt;/span&gt;&lt;/li&gt;
    &lt;li style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Realizar o workshop assim que poss&amp;iacute;vel e envolver os participantes apropriados se houver compreens&amp;atilde;o suficiente da oportunidade.&lt;/span&gt;&lt;/li&gt;
    &lt;li style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;O workshop &amp;eacute; uma sess&amp;atilde;o facilitada onde os participantes fazem brainstorming para sugerir atores e casos de uso usando o material de entrada e seu pr&amp;oacute;prio conhecimento e experi&amp;ecirc;ncia.&lt;/span&gt;&lt;/li&gt;
    &lt;li style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Os atores s&amp;atilde;o sugeridos principalmente com base nas categorias de usu&amp;aacute;rios que s&amp;atilde;o ent&amp;atilde;o transformadas em fun&amp;ccedil;&amp;otilde;es em rela&amp;ccedil;&amp;atilde;o ao sistema.&lt;/span&gt;&lt;/li&gt;
    &lt;li style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Os casos de uso s&amp;atilde;o sugeridos principalmente com base nos itens da oportunidade e nos objetivos dos atores quando est&amp;atilde;o usando o sistema.&lt;/span&gt;&lt;/li&gt;
    &lt;li style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;O grupo consolida os resultados do brainstorming em um modelo de caso de uso bem formado. Eles tamb&amp;eacute;m observam quaisquer requisitos que n&amp;atilde;o sejam considerados relacionados ao caso de uso.&amp;nbsp;&lt;/span&gt;&lt;/li&gt;
    &lt;li style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;O workshop deve envolver pessoas das comunidades de clientes e usu&amp;aacute;rios, pois isso resultar&amp;aacute; em um modelo de caso de uso melhor. Tamb&amp;eacute;m produz mais consenso e propriedade partilhada do modelo de casos de utiliza&amp;ccedil;&amp;atilde;o, o que, por sua vez, simplificar&amp;aacute; a obten&amp;ccedil;&amp;atilde;o de acordo. Tamb&amp;eacute;m pode ser apropriado envolver pessoas das &amp;aacute;reas de gest&amp;atilde;o e engenharia de software do projeto para transferir conhecimento e construir propriedade conjunta.&lt;/span&gt;&lt;/li&gt;
    &lt;li style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Pode ser necess&amp;aacute;rio realizar um conjunto de workshops de modelagem de casos de uso para garantir que todos os aspectos da solu&amp;ccedil;&amp;atilde;o proposta sejam cobertos.&lt;/span&gt;&lt;/li&gt;
&lt;/ul&gt;
&lt;p style=&quot;text-align: justify;&quot;&gt;____________&lt;/p&gt;
&lt;p style=&quot;text-align: center;&quot;&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;&lt;strong&gt;&lt;u&gt;Estruturar o modelo de caso de uso&lt;/u&gt;&lt;/strong&gt;&lt;/span&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/p&gt;
&lt;ul&gt;
    &lt;li style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Usar esta abordagem quando houver muita redund&amp;acirc;ncia entre os casos de uso, for dif&amp;iacute;cil expressar o comportamento da extens&amp;atilde;o ou refletir uma melhor compreens&amp;atilde;o dos casos de uso pela equipe de desenvolvimento.&lt;/span&gt;&lt;/li&gt;
&lt;/ul&gt;
&lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;Fatorar:&lt;/strong&gt;&lt;br&gt;&lt;/span&gt;&lt;/p&gt;
&lt;ul&gt;
    &lt;li style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Sequ&amp;ecirc;ncias comuns de comportamento como casos de uso que ser&amp;atilde;o inclu&amp;iacute;dos em outros casos de uso.&lt;/span&gt;&lt;/li&gt;
    &lt;li style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Sequ&amp;ecirc;ncias gen&amp;eacute;ricas como casos de uso abstratos que s&amp;atilde;o herdados usando o relacionamento de generaliza&amp;ccedil;&amp;atilde;o.&lt;/span&gt;&lt;/li&gt;
    &lt;li style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Comportamento de extens&amp;atilde;o como casos de uso que estendem outros casos de uso.&lt;/span&gt;&lt;/li&gt;
    &lt;li style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Tenha cuidado para n&amp;atilde;o tornar o modelo de casos de uso irreconhec&amp;iacute;vel para as pessoas que contribu&amp;iacute;ram para a sua cria&amp;ccedil;&amp;atilde;o inicial.&lt;/span&gt;&lt;/li&gt;
&lt;/ul&gt;
&lt;p style=&quot;text-align: justify;&quot;&gt;____________&lt;/p&gt;
&lt;p style=&quot;text-align: center;&quot;&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;&lt;strong&gt;&lt;u&gt;Altera&amp;ccedil;&amp;otilde;es no modelo de casos de uso&lt;/u&gt;&lt;/strong&gt;&lt;/span&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;Para cada solicita&amp;ccedil;&amp;atilde;o de altera&amp;ccedil;&amp;atilde;o:&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;
&lt;ul&gt;
    &lt;li style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Sequ&amp;ecirc;ncias comuns de comportamento como casos de uso que ser&amp;atilde;o inclu&amp;iacute;dos em outros casos de uso.&lt;/span&gt;&lt;/li&gt;
    &lt;li style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Sequ&amp;ecirc;ncias gen&amp;eacute;ricas como casos de uso abstratos que s&amp;atilde;o herdados usando o relacionamento de generaliza&amp;ccedil;&amp;atilde;o.&lt;/span&gt;&lt;/li&gt;
    &lt;li style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Comportamento de extens&amp;atilde;o como casos de uso que estendem outros casos de uso.&lt;/span&gt;&lt;/li&gt;
    &lt;li style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Tenha cuidado para n&amp;atilde;o tornar o modelo de casos de uso irreconhec&amp;iacute;vel para as pessoas que contribu&amp;iacute;ram para a sua cria&amp;ccedil;&amp;atilde;o inicial.&lt;/span&gt;&lt;/li&gt;
&lt;/ul&gt;
&lt;p&gt;&lt;br&gt;&lt;/p&gt;
&lt;p&gt;&lt;br&gt;&lt;/p&gt;</untitled-ontology-3:abordagens>
        <untitled-ontology-3:apresAtividade>&lt;ul&gt;
    &lt;li&gt;E&lt;span style=&quot;font-size: 12px;&quot;&gt;sta atividade resulta em atualiza&amp;ccedil;&amp;otilde;es no modelo de casos de uso e nas informa&amp;ccedil;&amp;otilde;es de suporte que s&amp;atilde;o usadas para descrever os requisitos do sistema.&lt;/span&gt;&lt;/li&gt;
    &lt;li&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;A melhor maneira de fazer isso &amp;eacute; realizar um workshop de modelagem de casos de uso com as partes interessadas.&amp;nbsp;&lt;/span&gt;&lt;/li&gt;
    &lt;li&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;N&amp;atilde;o h&amp;aacute; necessidade de encontrar todos os casos de uso do sistema, apenas concentre-se naqueles que ir&amp;atilde;o fornecer aos stakeholders o valor que eles procuram.&amp;nbsp;&lt;/span&gt;&lt;/li&gt;
    &lt;li&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Outros atores e casos de uso ser&amp;atilde;o encontrados &amp;agrave; medida que voc&amp;ecirc; inspeciona e adapta os casos de uso existentes.&lt;/span&gt;&lt;/li&gt;
    &lt;li&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&amp;Agrave; medida que os casos de uso s&amp;atilde;o descobertos, eles devem ser ordenados para dar suporte aos planos da equipe.&amp;nbsp;&lt;/span&gt;&lt;/li&gt;
    &lt;li&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Uma das melhores vantagens dos casos de uso &amp;eacute; que eles permitem o gerenciamento de escopo de alto n&amp;iacute;vel sem a necessidade de descobrir ou criar todas as hist&amp;oacute;rias.&amp;nbsp;&lt;/span&gt;&lt;/li&gt;
    &lt;li&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Se um caso de uso n&amp;atilde;o for necess&amp;aacute;rio, n&amp;atilde;o h&amp;aacute; necessidade de discutir ou documentar suas hist&amp;oacute;rias.&amp;nbsp;&lt;/span&gt;&lt;/li&gt;
    &lt;li&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Se o caso de uso estiver dentro do escopo, ele dever&amp;aacute; ser delineado para que haja informa&amp;ccedil;&amp;otilde;es suficientes para iniciar o processo de fatiamento.&lt;/span&gt;&lt;/li&gt;
    &lt;li&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Repetir esta atividade conforme necess&amp;aacute;rio para evoluir seu modelo e encontrar atores ou casos de uso ausentes.&lt;/span&gt;&lt;/li&gt;
&lt;/ul&gt;
&lt;p&gt;&lt;br&gt;&lt;/p&gt;</untitled-ontology-3:apresAtividade>
        <untitled-ontology-3:descricao>&lt;ul&gt;
    &lt;li style=&quot;font-size: 12px;&quot;&gt;Concordar com os objetivos do sistema.&lt;/li&gt;
    &lt;li style=&quot;font-size: 12px;&quot;&gt;Concordar com o novo comportamento do sistema.&lt;/li&gt;
    &lt;li style=&quot;font-size: 12px;&quot;&gt;Escopo de uma vers&amp;atilde;o do sistema.&lt;/li&gt;
    &lt;li style=&quot;font-size: 12px;&quot;&gt;Concordar com o valor que o sistema oferece.&lt;/li&gt;
    &lt;li style=&quot;font-size: 12px;&quot;&gt;Identificar maneiras de usar e testar o sistema.&lt;/li&gt;
    &lt;li style=&quot;font-size: 12px; font-weight: bold;&quot;&gt;&lt;strong&gt;Esta atividade estar&amp;aacute; conclu&amp;iacute;da quando a equipe concordar que os resultados refletem a oportunidade dentro do escopo.&lt;/strong&gt;&lt;/li&gt;
&lt;/ul&gt;
&lt;p&gt;&lt;br&gt;&lt;/p&gt;
&lt;p&gt;&lt;br&gt;&lt;/p&gt;</untitled-ontology-3:descricao>
        <untitled-ontology-3:infAdicionais>&lt;div style=&quot;text-align: justify; color: rgb(0, 0, 0); font-size: 16px;&quot;&gt;
    &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;&lt;u&gt;Participantes:&lt;/u&gt;&lt;/strong&gt;&lt;br&gt;&lt;/span&gt;&lt;/p&gt;
    &lt;p&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;O respons&amp;aacute;vel por esta atividade deve:&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;
    &lt;ul&gt;
        &lt;li&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Identificar e compreender os problemas e oportunidades relacionados ao uso do sistema.&lt;/span&gt;&lt;/li&gt;
        &lt;li&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Capturar, compreender e comunicar as necessidades expressadas pelos outros participantes.&lt;/span&gt;&lt;/li&gt;
        &lt;li&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Produzir um modelo de caso de uso sensato.&lt;/span&gt;&lt;/li&gt;
        &lt;li&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Representa&amp;ccedil;&amp;atilde;o das partes interessadas:&lt;/span&gt;&lt;/li&gt;
        &lt;li&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Os representantes das partes interessadas desempenham o importante papel de garantir que o modelo de caso de uso emergente atenda &amp;agrave;s necessidades e expectativas mais importantes da comunidade de partes interessadas.&lt;/span&gt;&lt;/li&gt;
    &lt;/ul&gt;
    &lt;p&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;O analista deve garantir que haja conhecimento suficiente do cliente envolvido para:&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;
    &lt;ul&gt;
        &lt;li&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Identificar os atores certos.&lt;/span&gt;&lt;/li&gt;
        &lt;li&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Identificar casos de uso que fornecer&amp;atilde;o o valor que os usu&amp;aacute;rios precisam do sistema.&lt;/span&gt;&lt;/li&gt;
        &lt;li&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Entender o impacto que o sistema ter&amp;aacute; nos usu&amp;aacute;rios e nos processos de neg&amp;oacute;cios.&lt;/span&gt;&lt;/li&gt;
    &lt;/ul&gt;
    &lt;p&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;O n&amp;iacute;vel de conhecimento necess&amp;aacute;rio variar&amp;aacute; de acordo com a complexidade do dom&amp;iacute;nio que est&amp;aacute; sendo modelado. Quanto mais complexo for o dom&amp;iacute;nio, maior ser&amp;aacute; o n&amp;iacute;vel de conhecimento que a equipe de desenvolvimento precisar&amp;aacute; utilizar.&lt;br&gt;&lt;/span&gt;&lt;/p&gt;
&lt;/div&gt;
&lt;p style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 16px;&quot;&gt;_______________&lt;/p&gt;
&lt;p style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 16px;&quot;&gt;&lt;strong&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;u&gt;Refer&amp;ecirc;ncias de apoio&lt;/u&gt;&lt;/span&gt;&lt;/strong&gt;&lt;/p&gt;
&lt;p style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 12px;&quot;&gt;&lt;sup&gt;&lt;sup style=&quot;font-size: smaller;&quot;&gt;1&lt;/sup&gt;&lt;/sup&gt; Use Case Modeling, de Kurt Bittner e Ian Spence, Addison-Wesley Professional, cap&amp;iacute;tulos 4-5.&lt;/p&gt;
&lt;p style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 12px;&quot;&gt;&lt;sup&gt;&lt;sup style=&quot;font-size: smaller;&quot;&gt;2&lt;/sup&gt;&lt;/sup&gt; Use Case Patterns and Blueprints, por Gunnar &amp;Ouml;vergaard e Karin Palmkvist, Addison Wesley, cap&amp;iacute;tulos 16-44.&lt;/p&gt;</untitled-ontology-3:infAdicionais>
