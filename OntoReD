    <!-- http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#InspecionarCasoUso -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#InspecionarCasoUso">
        <rdf:type rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#AtividadeProdutoTrabalho"/>
        <untitled-ontology-3:produz rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#NarrativaCasoUso"/>
        <untitled-ontology-3:Icone>&lt;p&gt;Icone Atividade Produto Trabalho&lt;/p&gt;</untitled-ontology-3:Icone>
        <untitled-ontology-3:abordagens>&lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;A abordagem a adotar depende do estado do projeto.&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;
&lt;div style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 16px;&quot;&gt;
    &lt;h2 style=&quot;font-size: 1.75em;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;____________________&lt;/span&gt;&lt;/h2&gt;
    &lt;h2 style=&quot;font-size: 1.75em; text-align: center;&quot;&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;&lt;u&gt;Retrospectivo&lt;/u&gt;&lt;/span&gt;&lt;/h2&gt;
    &lt;p style=&quot;font-size: 1em;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;Usar esta abordagem para equilibrar o esfor&amp;ccedil;o necess&amp;aacute;rio entre o detalhamento de narrativas de casos de uso e casos de teste.&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;
    &lt;p style=&quot;font-size: 1em;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;Discutir e investigar com a equipe:&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;
    &lt;ul&gt;
        &lt;li style=&quot;font-size: 12px;&quot;&gt;A necessidade da profundidade e amplitude atuais da narrativa de casos de uso.&lt;/li&gt;
        &lt;li style=&quot;font-size: 12px;&quot;&gt;A fonte dos defeitos.&lt;/li&gt;
        &lt;li style=&quot;font-size: 12px;&quot;&gt;A necessidade de atualizar as diretrizes para promover a consist&amp;ecirc;ncia.&lt;/li&gt;
    &lt;/ul&gt;
&lt;/div&gt;
&lt;div style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 16px;&quot;&gt;
    &lt;h2 style=&apos;margin: 10px 0px; color: rgb(0, 0, 0); font-family: &quot;Times New Roman&quot;; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; background-color: rgb(255, 255, 255); text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; font-size: 1.75em;&apos;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;____________________&lt;/span&gt;&lt;/h2&gt;
    &lt;h2 style=&quot;font-size: 1.75em; text-align: center;&quot;&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;&lt;u&gt;Revis&amp;atilde;o do modelo de caso de uso&lt;/u&gt;&lt;/span&gt;&lt;/h2&gt;
    &lt;p style=&quot;font-size: 1em;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;Usar esta abordagem quando houver muitas semelhan&amp;ccedil;as na narrativa de casos de uso.&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;
    &lt;p style=&quot;font-size: 1em;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;Procurar oportunidades para reduzir o esfor&amp;ccedil;o de autoria usando:&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;
    &lt;ul&gt;
        &lt;li style=&quot;font-size: 12px;&quot;&gt;Inclui relacionamentos.&lt;/li&gt;
        &lt;li style=&quot;font-size: 12px;&quot;&gt;Generalize os relacionamentos.&lt;/li&gt;
    &lt;/ul&gt;
    &lt;p style=&quot;font-size: 1em;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;Procurar oportunidades para reduzir a complexidade ou adicionar flexibilidade:&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;
    &lt;ul&gt;
        &lt;li style=&quot;font-size: 12px;&quot;&gt;Ampliar relacionamentos.&lt;/li&gt;
    &lt;/ul&gt;
&lt;/div&gt;
&lt;div style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 16px;&quot;&gt;
    &lt;h2 style=&apos;margin: 10px 0px; color: rgb(0, 0, 0); font-family: &quot;Times New Roman&quot;; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; background-color: rgb(255, 255, 255); text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; font-size: 1.75em;&apos;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;____________________&lt;/span&gt;&lt;/h2&gt;
    &lt;h2 style=&quot;font-size: 1.75em; text-align: center;&quot;&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;&lt;u&gt;Mudar a gest&amp;atilde;o&lt;/u&gt;&lt;/span&gt;&lt;/h2&gt;
    &lt;p style=&quot;font-size: 1em;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;Use esta abordagem quando um caso de uso ou de teste precisar ser atualizado para refletir altera&amp;ccedil;&amp;otilde;es nos requisitos do sistema.&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;
    &lt;p style=&quot;font-size: 1em;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;&amp;Agrave; medida que os requisitos mudam, o impacto pode resultar em:&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;
    &lt;ul&gt;
        &lt;li style=&quot;font-size: 12px;&quot;&gt;Adicionar, atualizar ou remover hist&amp;oacute;rias.&lt;/li&gt;
        &lt;li style=&quot;font-size: 12px;&quot;&gt;Adicionar, atualizar, dividir ou remover fatias de casos de uso.&lt;/li&gt;
        &lt;li style=&quot;font-size: 12px;&quot;&gt;Adicionar, atualizar ou remover informa&amp;ccedil;&amp;otilde;es de suporte.&lt;/li&gt;
        &lt;li style=&quot;font-size: 12px;&quot;&gt;Alterar as regras que regem como as fatias de casos de uso s&amp;atilde;o ordenadas.&lt;/li&gt;
        &lt;li style=&quot;font-size: 12px;&quot;&gt;Alterar a &amp;ldquo;defini&amp;ccedil;&amp;atilde;o de pronto&amp;rdquo;.&lt;/li&gt;
    &lt;/ul&gt;
    &lt;p style=&quot;font-size: 1em;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;&amp;Agrave; medida que os requisitos mudam, um teste pode precisar ser reconstru&amp;iacute;do. Isso pode envolver:&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;
    &lt;ul&gt;
        &lt;li style=&quot;font-size: 12px;&quot;&gt;Adicionar o casos de teste a casos de uso.&lt;/li&gt;
        &lt;li style=&quot;font-size: 12px;&quot;&gt;Remover casos de teste de casos de uso.&lt;/li&gt;
        &lt;li style=&quot;font-size: 12px;&quot;&gt;Especificar uma nova vers&amp;atilde;o de um caso de teste.&lt;/li&gt;
    &lt;/ul&gt;
&lt;/div&gt;</untitled-ontology-3:abordagens>
        <untitled-ontology-3:apresAtividade>&lt;p style=&quot;text-align: center;&quot;&gt;&lt;/p&gt;
&lt;ul&gt;
    &lt;li style=&quot;text-align: justify; color: rgb(0, 0, 0); font-size: 16px;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&amp;Agrave; medida que o projeto avan&amp;ccedil;a, &amp;eacute; essencial que voc&amp;ecirc; trabalhe continuamente com seu modelo de casos de uso, casos de uso e fatias de casos de uso. As prioridades mudam, as li&amp;ccedil;&amp;otilde;es s&amp;atilde;o aprendidas e as mudan&amp;ccedil;as s&amp;atilde;o solicitadas. Tudo isso pode ter um impacto nos casos de uso e nas fatias de casos de uso que j&amp;aacute; foram implementados, bem como naqueles que ainda aguardam progresso. Esta atividade muitas vezes levar&amp;aacute; &amp;agrave; descoberta de novos casos de uso e &amp;agrave; refatora&amp;ccedil;&amp;atilde;o dos casos de uso e fatias de casos de uso existentes.&lt;/span&gt;&lt;/li&gt;
    &lt;li style=&quot;text-align: justify; color: rgb(0, 0, 0); font-size: 16px;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;As diversas demandas do projeto podem exigir que voc&amp;ecirc; ajuste o uso do Use-Case 2.0 Essentials e ajuste o tamanho das fatias (sua amplitude) ou o n&amp;iacute;vel de detalhe (sua profundidade) em suas narrativas de caso de uso, informa&amp;ccedil;&amp;otilde;es de apoio e teste casos.&amp;nbsp;&amp;Eacute; importante que voc&amp;ecirc; inspecione e adapte continuamente sua maneira de trabalhar, bem como os casos de uso e as fatias de casos de uso com os quais est&amp;aacute; trabalhando.&lt;/span&gt;&lt;/li&gt;
    &lt;li style=&quot;text-align: justify; color: rgb(0, 0, 0); font-size: 16px;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Depois de ajustar o modelo de casos de uso e atualizar tudo, voc&amp;ecirc; estar&amp;aacute; pronto para identificar seu pr&amp;oacute;ximo conjunto de fatias.&lt;/span&gt;&lt;/li&gt;
&lt;/ul&gt;
&lt;p&gt;&lt;/p&gt;</untitled-ontology-3:apresAtividade>
        <untitled-ontology-3:descricao>&lt;p style=&quot;text-align: center;&quot;&gt;&lt;/p&gt;
&lt;p style=&quot;font-size: 1em; text-align: justify;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;Lidar com as mudan&amp;ccedil;as e acompanhar o progresso ajustando o modelo de casos de uso, os casos de uso e as fatias de casos de uso.&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;
&lt;p&gt;&lt;/p&gt;
&lt;div style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 16px;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;Ajustar e avaliar continuamente os casos de uso e as fatias de casos de uso para:&lt;/strong&gt;&lt;/span&gt;&lt;/div&gt;
&lt;ul style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 16px;&quot;&gt;
    &lt;li style=&quot;font-size: 12px;&quot;&gt;Lidar com mudan&amp;ccedil;as.&lt;/li&gt;
    &lt;li style=&quot;font-size: 12px;&quot;&gt;Acompanhar o progresso.&lt;/li&gt;
    &lt;li style=&quot;font-size: 12px;&quot;&gt;Ajustar seu trabalho dentro do tempo e or&amp;ccedil;amento dispon&amp;iacute;veis.&lt;/li&gt;
    &lt;li style=&quot;font-size: 12px;&quot;&gt;Manter o modelo de casos de uso atualizado.&lt;/li&gt;
    &lt;li style=&quot;font-size: 12px;&quot;&gt;Ajustar o tamanho das fatias para aumentar o rendimento.&lt;/li&gt;
&lt;/ul&gt;</untitled-ontology-3:descricao>
        <untitled-ontology-3:infAdicionais>&lt;div style=&quot;text-align: justify; color: rgb(0, 0, 0); font-size: 16px;&quot;&gt;
    &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;u&gt;&lt;strong&gt;Participantes&lt;/strong&gt;&lt;/u&gt;&lt;/span&gt;&lt;/p&gt;
    &lt;ul&gt;
        &lt;li style=&quot;text-align: justify; color: rgb(0, 0, 0); font-size: 16px;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Embora partes desta atividade possam ser realizadas por indiv&amp;iacute;duos, esta atividade &amp;eacute; melhor realizada como uma atividade de equipa liderada pelo l&amp;iacute;der da equipa.&lt;/span&gt;&lt;/li&gt;
        &lt;li style=&quot;text-align: justify; color: rgb(0, 0, 0); font-size: 16px;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Para poder realizar esta atividade com sucesso, todas as compet&amp;ecirc;ncias essenciais de engenharia de software precisam estar implementadas. Isto pode ser conseguido envolvendo toda a equipe ou apenas os l&amp;iacute;deres de cada &amp;aacute;rea de desenvolvimento.&lt;/span&gt;&lt;/li&gt;
    &lt;/ul&gt;
    &lt;h3 style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 1.3125em;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;u&gt;Representa&amp;ccedil;&amp;atilde;o das Partes Interessadas&lt;/u&gt;&lt;/span&gt;&lt;/h3&gt;
    &lt;p style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 16px;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Esta compet&amp;ecirc;ncia &amp;eacute; necess&amp;aacute;ria para determinar o progresso, tratar e priorizar adequadamente os defeitos e adicionar novos requisitos ao escopo, tudo sob a perspectiva das partes interessadas.&amp;nbsp;&lt;/span&gt;&lt;/p&gt;
    &lt;h3 style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 1.3125em;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;An&amp;aacute;lise&lt;/span&gt;&lt;/h3&gt;
    &lt;ul&gt;
        &lt;li style=&quot;text-align: justify; color: rgb(0, 0, 0); font-size: 16px;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Pessoas precisam estar envolvidas para o tratamento adequado de defeitos e mudan&amp;ccedil;as de escopo, bem como ajudar os demais participantes na tomada de decis&amp;otilde;es.&lt;/span&gt;&lt;/li&gt;
        &lt;li style=&quot;text-align: justify; color: rgb(0, 0, 0); font-size: 16px;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;As mudan&amp;ccedil;as no escopo podem resultar em um modelo de casos de uso atualizado ou reestruturado, em atualiza&amp;ccedil;&amp;otilde;es de fatias de casos de uso existentes ou em informa&amp;ccedil;&amp;otilde;es de suporte ou, at&amp;eacute; mesmo, em novos requisitos.&lt;/span&gt;&lt;/li&gt;
    &lt;/ul&gt;
    &lt;h3 style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 1.3125em;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Desenvolvimento&lt;/span&gt;&lt;/h3&gt;
    &lt;ul&gt;
        &lt;li style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 16px;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Pessoas precisam estar envolvidas para o tratamento adequado de defeitos (por exemplo, complexidade e dimensionamento).&lt;/span&gt;&lt;/li&gt;
    &lt;/ul&gt;
    &lt;h3 style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 1.3125em;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Teste&lt;/span&gt;&lt;/h3&gt;
    &lt;ul&gt;
        &lt;li style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 16px;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Pessoas precisam estar envolvidas para determinar o progresso e o tratamento adequado dos defeitos (por exemplo, gravidade).&lt;/span&gt;&lt;/li&gt;
    &lt;/ul&gt;
    &lt;h2 style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 1.75em;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;u&gt;Dicas e sugest&amp;otilde;es&lt;/u&gt;&lt;/span&gt;&lt;/h2&gt;
    &lt;h3 style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 1.3125em;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Monitore e ajuste continuamente seu conjunto de fatias de casos de uso no escopo&lt;/span&gt;&lt;/h3&gt;
    &lt;ul&gt;
        &lt;li style=&quot;text-align: justify; color: rgb(0, 0, 0); font-size: 16px;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Ao ordenar suas fatias de casos de uso e rastrear seus estados, voc&amp;ecirc; cria uma lista dos requisitos que ainda precisam ser implementados. Esta lista deve ser continuamente monitorada e ajustada para refletir o progresso da equipe e os desejos das partes interessadas.&lt;/span&gt;&lt;/li&gt;
        &lt;li style=&quot;text-align: justify; color: rgb(0, 0, 0); font-size: 16px;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&amp;Agrave; medida que o projeto avan&amp;ccedil;a, voc&amp;ecirc; deve monitorar e ajustar o tamanho da fatia, o tamanho do lote e os limites do trabalho em andamento para eliminar desperd&amp;iacute;cios e melhorar a efic&amp;aacute;cia da equipe.&lt;/span&gt;&lt;/li&gt;
    &lt;/ul&gt;
    &lt;h3 style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 1.3125em;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Adicione casos de teste para defeitos&lt;/span&gt;&lt;/h3&gt;
    &lt;ul&gt;
        &lt;li style=&quot;text-align: justify; color: rgb(0, 0, 0); font-size: 16px;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Quando forem encontrados defeitos que n&amp;atilde;o foram capturados pelos casos de teste identificados, adicione casos de teste &amp;agrave;s fatias de casos de uso que cobrem hist&amp;oacute;rias que incluem esses defeitos para avaliar sua resolu&amp;ccedil;&amp;atilde;o e evitar seu reaparecimento.&lt;/span&gt;&lt;/li&gt;
    &lt;/ul&gt;
    &lt;h2 style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 1.75em;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;u&gt;Erros comuns&lt;/u&gt;&lt;/span&gt;&lt;/h2&gt;
    &lt;h3 style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 1.3125em;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Defini&amp;ccedil;&amp;atilde;o de feito n&amp;atilde;o est&amp;aacute; clara em rela&amp;ccedil;&amp;atilde;o a defeitos&lt;/span&gt;&lt;/h3&gt;
    &lt;ul&gt;
        &lt;li style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 16px;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;O estado de uma fatia de caso de uso depende do progresso realizado e, em um mundo ideal, n&amp;atilde;o deveria ter defeitos relacionados. Contudo, no mundo real, o software raramente est&amp;aacute; isento de defeitos; al&amp;eacute;m disso, nem todos os defeitos precisam ser tratados igualmente.&lt;/span&gt;&lt;/li&gt;
        &lt;li style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 16px;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;Problema&lt;/strong&gt; : Visar a perfei&amp;ccedil;&amp;atilde;o resolvendo todos os defeitos atrasa, ou at&amp;eacute; impede, a entrega.&lt;strong&gt;&lt;br&gt;&lt;/strong&gt;&lt;/span&gt;&lt;/li&gt;
        &lt;li style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 16px;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;Resolu&amp;ccedil;&amp;atilde;o&lt;/strong&gt; : Desenvolva um esquema de prioriza&amp;ccedil;&amp;atilde;o de defeitos com base na gravidade, prioridade e tipo de defeito onde:&lt;/span&gt;&lt;/li&gt;
        &lt;li style=&quot;text-align: justify; font-size: 12px;&quot;&gt;A gravidade determina o impacto de um defeito em rela&amp;ccedil;&amp;atilde;o ao sistema (por exemplo, falha com perda de dados, falha direta, impacto na usabilidade, problema cosm&amp;eacute;tico, novo recurso).&lt;/li&gt;
        &lt;li style=&quot;text-align: justify; font-size: 12px;&quot;&gt;A prioridade reflete a vis&amp;atilde;o do projeto sobre o defeito, a fim de program&amp;aacute;-lo para uma solu&amp;ccedil;&amp;atilde;o (por exemplo, disponibilidade de uma solu&amp;ccedil;&amp;atilde;o alternativa, complexidade ou dificuldade de corre&amp;ccedil;&amp;atilde;o).&lt;/li&gt;
        &lt;li style=&quot;text-align: justify; font-size: 12px;&quot;&gt;O tipo determina o que &amp;eacute; afetado (por exemplo, requisitos, design, c&amp;oacute;digo, manuais, casos de teste, documenta&amp;ccedil;&amp;atilde;o, hardware, sistema operacional, uso indesejado do sistema).&lt;/li&gt;
    &lt;/ul&gt;
    &lt;p style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 16px;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Trabalhar com as partes interessadas para determinar quais n&amp;iacute;veis de defeitos ou tipos de defeitos s&amp;atilde;o aceit&amp;aacute;veis para passar na &amp;ldquo;defini&amp;ccedil;&amp;atilde;o de conclu&amp;iacute;do&amp;rdquo;.&lt;/span&gt;&lt;/p&gt;
&lt;/div&gt;
&lt;p style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 16px;&quot;&gt;_______________&lt;/p&gt;
&lt;p style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 16px;&quot;&gt;&lt;strong&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;u&gt;Refer&amp;ecirc;ncias de apoio&lt;/u&gt;&lt;/span&gt;&lt;/strong&gt;&lt;/p&gt;
&lt;p&gt;&lt;sup&gt;&lt;sup style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: smaller;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;1&lt;/span&gt;&lt;/sup&gt;&lt;/sup&gt;&lt;span style=&quot;text-align: start; color: rgb(0, 0, 0); font-size: 12px;&quot;&gt;&amp;nbsp;Use Case Modeling, by Kurt Bittner and Ian Spence, Addison-Wesley Professional, chapter 10.&lt;/span&gt;&lt;/p&gt;</untitled-ontology-3:infAdicionais>
        <untitled-ontology-3:nome>&lt;p&gt;Inspecionar e ajustar os casos de uso&lt;/p&gt;</untitled-ontology-3:nome>
        <untitled-ontology-3:sequencia rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">6</untitled-ontology-3:sequencia>
        <untitled-ontology-3:sequenciaAtividadeUC rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">4</untitled-ontology-3:sequenciaAtividadeUC>
    </owl:NamedIndividual>
    


