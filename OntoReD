    <!-- http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#TestarSistema -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#TestarSistema">
        <rdf:type rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#EspacoAtividade"/>
        <untitled-ontology-3:contempla rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#InspecionarCasoUso"/>
        <untitled-ontology-3:Icone>&lt;p&gt;Icone Espaco Atividade&lt;/p&gt;</untitled-ontology-3:Icone>
        <untitled-ontology-3:descricao>&lt;div style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 16px;&quot;&gt;
    &lt;div style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 16px;&quot;&gt;
        &lt;div style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 16px;&quot;&gt;
            &lt;p style=&quot;font-size: 1em; text-align: left;&quot;&gt;&lt;/p&gt;
            &lt;p style=&quot;font-size: 1em;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;Verificar se o sistema produzido atende aos requisitos das partes interessadas.&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;
            &lt;p&gt;&lt;/p&gt;
            &lt;p style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 16px;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;Testar o sistema para:&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;
            &lt;ul&gt;
                &lt;li style=&quot;font-size: 12px; text-align: justify;&quot;&gt;Verificar se o sistema de software atende aos requisitos.&lt;/li&gt;
                &lt;li style=&quot;font-size: 12px; text-align: justify;&quot;&gt;Identificar quaisquer defeitos no sistema de software.&lt;/li&gt;
            &lt;/ul&gt;
        &lt;/div&gt;
    &lt;/div&gt;
&lt;/div&gt;
&lt;div style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 16px;&quot;&gt;
    &lt;p&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;Refer&amp;ecirc;ncias:&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;
    &lt;ul&gt;
        &lt;li style=&quot;font-size: 12px; color: rgb(0, 0, 0);&quot;&gt;Essence Standard (OMG), consulte &lt;u&gt;&lt;a href=&quot;http://www.omg.org/spec/Essence/1.1/&quot; target=&quot;_blank&quot; style=&quot;color: rgb(75, 110, 198);&quot;&gt;http://www.omg.org/spec/Essence/1.1/&lt;/a&gt;&lt;/u&gt;&lt;/li&gt;
