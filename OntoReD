    <!-- http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#PlanejamentoPreparacaoRevReq -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#PlanejamentoPreparacaoRevReq">
        <rdf:type rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#PassosElementosPrática"/>
        <untitled-ontology-3:estaContidoEm rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#ModeloRevisaoRequisitos"/>
        <untitled-ontology-3:descricao>&lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&apos;font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;&lt;strong&gt;O primeiro passo para realizar a revis&amp;atilde;o de requisitos &amp;eacute; definir, neste n&amp;iacute;vel:&amp;nbsp;&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;
&lt;ul&gt;
    &lt;li style=&apos;list-style-type: disc; font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;
        &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Os envolvidos na revis&amp;atilde;o, ou seja, os revisores que revisar&amp;atilde;o o artefato.&lt;/span&gt;&lt;/p&gt;
    &lt;/li&gt;
    &lt;li style=&apos;list-style-type: disc; font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;
        &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;O projeto no qual o artefato que ser&amp;aacute; revisado est&amp;aacute; vinculado.&lt;/span&gt;&lt;/p&gt;
    &lt;/li&gt;
    &lt;li style=&apos;list-style-type: disc; font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;
        &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;O artefato que ser&amp;aacute; revisado e sua vers&amp;atilde;o.&lt;/span&gt;&lt;/p&gt;
    &lt;/li&gt;
    &lt;li style=&apos;list-style-type: disc; font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;
        &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;O objetivo da revis&amp;atilde;o.&lt;/span&gt;&lt;/p&gt;
    &lt;/li&gt;
    &lt;li style=&apos;list-style-type: disc; font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;
        &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;A &amp;nbsp;previs&amp;atilde;o da data da revis&amp;atilde;o.&lt;/span&gt;&lt;/p&gt;
    &lt;/li&gt;
    &lt;li style=&apos;list-style-type: disc; font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;
        &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;A estimativa de esfor&amp;ccedil;o que ser&amp;aacute; dedicada &amp;agrave; revis&amp;atilde;o.&lt;/span&gt;&lt;/p&gt;
    &lt;/li&gt;
&lt;/ul&gt;
&lt;p&gt;&lt;span style=&apos;font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;S&amp;atilde;o envolvidas, de tr&amp;ecirc;s a cinco pessoas em uma revis&amp;atilde;o (normalmente). Realizar uma prepara&amp;ccedil;&amp;atilde;o antecipada por&amp;eacute;m, a revis&amp;atilde;o n&amp;atilde;o deve exigir mais do que duas horas de trabalho de cada pessoa (PRESSMAN; MAXIM &amp;nbsp;2021).&lt;/span&gt;&lt;/p&gt;</untitled-ontology-3:descricao>
        <untitled-ontology-3:nome>&lt;p style=&quot;text-align: center;&quot;&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;&lt;strong&gt;Planejamento e Prepara&amp;ccedil;&amp;atilde;o&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;</untitled-ontology-3:nome>
        <untitled-ontology-3:sequencia rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">1</untitled-ontology-3:sequencia>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#PlanejarRastreabilidadeRequisitos -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#PlanejarRastreabilidadeRequisitos">
