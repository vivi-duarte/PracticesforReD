&lt;p&gt;&lt;span style=&apos;font-size: 8pt; font-family: &quot;Times New Roman&quot;, serif; font-variant-numeric: normal; font-variant-east-asian: normal; font-variant-alternates: normal; font-variant-position: normal; vertical-align: baseline; white-space-collapse: preserve;&apos;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;Fonte: Informa&amp;ccedil;&amp;otilde;es adaptadas de IEEE, 2018; Summerville, 2018&amp;nbsp;&lt;/span&gt;&lt;/p&gt;
&lt;p dir=&quot;ltr&quot; style=&quot;line-height: 1.2; text-indent: 21.2598pt; margin-top: 0pt; margin-bottom: 0pt; text-align: center;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;Descri&amp;ccedil;&amp;atilde;o dos itens do documento:&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;
&lt;ul&gt;
