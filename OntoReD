        <untitled-ontology-3:Icone>&lt;p&gt;Icone Atividade Produto Trabalho&lt;/p&gt;</untitled-ontology-3:Icone>
        <untitled-ontology-3:descricao>&lt;ul&gt;
    &lt;li style=&quot;font-size: 12px; text-align: justify;&quot;&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;A rastreabilidade de requisitos deve ser acompanhada e gerenciada durante o desenvolvimento do software, pois se mudan&amp;ccedil;as forem propostas e ocorrerem, ir&amp;aacute; refletir diretamente na rastreabilidade. Dessa forma, &amp;eacute; necess&amp;aacute;rio realizar a manuten&amp;ccedil;&amp;atilde;o da rastreabilidade.&lt;/span&gt;&lt;/li&gt;
&lt;/ul&gt;</untitled-ontology-3:descricao>
        <untitled-ontology-3:nome>&lt;p&gt;Acompanhar e manter a rastreabilidade de requisitos&lt;/p&gt;</untitled-ontology-3:nome>
        <untitled-ontology-3:sequencia rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">6</untitled-ontology-3:sequencia>
        <untitled-ontology-3:sequenciaAtividadeUC rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">3</untitled-ontology-3:sequenciaAtividadeUC>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#Analisado -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#Analisado">
        <rdf:type rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#EstadoAlpha"/>
        <untitled-ontology-3:avancadoPor rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#AnalisarParteCasoUso"/>
        <untitled-ontology-3:Icone>&lt;p&gt;Icone Estado Alpha&lt;/p&gt;</untitled-ontology-3:Icone>
        <untitled-ontology-3:descricao>&lt;ul&gt;
    &lt;li style=&quot;font-size: 12px; text-align: justify;&quot;&gt;&lt;span style=&quot;text-align: left; color: rgb(0, 0, 0);&quot;&gt;&lt;strong&gt;A fatia do caso de uso foi analisada de forma que seu impacto nos componentes do sistema seja compreendido e as partes afetadas estejam prontas para implementa&amp;ccedil;&amp;atilde;o e teste.&lt;/strong&gt;&lt;/span&gt;&lt;/li&gt;
    &lt;li style=&quot;font-size: 12px; text-align: justify;&quot;&gt;&lt;strong&gt;Informa&amp;ccedil;&amp;otilde;es suficientes para implementar com sucesso:&amp;nbsp;&lt;/strong&gt;As realiza&amp;ccedil;&amp;otilde;es de casos de uso da parte do caso de uso cont&amp;ecirc;m informa&amp;ccedil;&amp;otilde;es suficientes para permitir que os fluxos relevantes, os requisitos especiais e as informa&amp;ccedil;&amp;otilde;es de suporte cobertas pela fatia de caso de uso sejam implementados com &amp;ecirc;xito.&amp;nbsp;&lt;/li&gt;
    &lt;li style=&quot;font-size: 12px; text-align: justify;&quot;&gt;&lt;strong&gt;O impacto da implementa&amp;ccedil;&amp;atilde;o &amp;eacute; acordado:&amp;nbsp;&lt;/strong&gt;Deve ser acordado como a implementa&amp;ccedil;&amp;atilde;o da fatia impactar&amp;aacute; os elementos de implementa&amp;ccedil;&amp;atilde;o (novos ou existentes).&amp;nbsp;&lt;/li&gt;
    &lt;li style=&quot;font-size: 12px; text-align: justify;&quot;&gt;&lt;strong&gt;O impacto &amp;eacute; aceit&amp;aacute;vel:&amp;nbsp;&lt;/strong&gt;O impacto previsto &amp;eacute; aceit&amp;aacute;vel.&lt;/li&gt;
    &lt;li style=&quot;font-size: 12px; text-align: justify;&quot;&gt;&lt;strong&gt;A&lt;/strong&gt;&lt;strong&gt;s realiza&amp;ccedil;&amp;otilde;es de casos de uso s&amp;atilde;o Elementos de implementa&amp;ccedil;&amp;atilde;o identificados:&lt;/strong&gt; As realiza&amp;ccedil;&amp;otilde;es dos casos de uso para a fatia s&amp;atilde;o detalhadas.&lt;/li&gt;
&lt;/ul&gt;</untitled-ontology-3:descricao>
        <untitled-ontology-3:nome>&lt;p&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;&lt;strong&gt;Analisado&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;</untitled-ontology-3:nome>
        <untitled-ontology-3:sequencia rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">3</untitled-ontology-3:sequencia>
    </owl:NamedIndividual>
    


