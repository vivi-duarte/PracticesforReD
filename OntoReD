    <!-- http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#MoldarSistema -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#MoldarSistema">
        <rdf:type rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#EspacoAtividade"/>
        <untitled-ontology-3:contempla rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#AnalisarParteCasoUso"/>
        <untitled-ontology-3:Icone>&lt;p&gt;Icone Espaco Atividade&lt;/p&gt;</untitled-ontology-3:Icone>
        <untitled-ontology-3:descricao>&lt;div style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 16px;&quot;&gt;
    &lt;p style=&quot;font-size: 1em;&quot;&gt;&lt;strong&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Modelar o sistema para que seja f&amp;aacute;cil de desenvolver, alterar e manter, e possa lidar com as demandas atuais e futuras.&amp;nbsp;&lt;/span&gt;&lt;/strong&gt;&lt;/p&gt;
    &lt;ul&gt;
        &lt;li style=&quot;font-size: 12px;&quot;&gt;Isso inclui o design geral e a arquitetura do sistema a ser desenvolvido.&lt;/li&gt;
    &lt;/ul&gt;
&lt;/div&gt;
&lt;p style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 16px;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;Modelar o sistema para:&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;
&lt;ul style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 16px;&quot;&gt;
    &lt;li style=&quot;font-size: 12px;&quot;&gt;Estruturar o sistema e identifique os principais elementos do sistema.&lt;/li&gt;
    &lt;li style=&quot;font-size: 12px;&quot;&gt;Atribuir requisitos aos elementos do sistema.&lt;/li&gt;
    &lt;li style=&quot;font-size: 12px;&quot;&gt;Certificar-se de que a arquitetura seja adequadamente robusta e flex&amp;iacute;vel.&lt;/li&gt;
&lt;/ul&gt;
&lt;div style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 16px;&quot;&gt;
    &lt;h1 style=&quot;text-align: start;color: rgb(0, 0, 0);font-size: 2.375em;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;Atividade dispon&amp;iacute;vel - Contempla:&lt;/span&gt;&lt;/h1&gt;
    &lt;ul&gt;
        &lt;li&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;Analisar uma fatia de caso de uso:&lt;/strong&gt; Analisar o impacto de uma fatia de Caso de Uso e moldar sua implementa&amp;ccedil;&amp;atilde;o.&lt;/span&gt;&lt;/li&gt;
    &lt;/ul&gt;
    &lt;p&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;Refer&amp;ecirc;ncias:&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;
    &lt;ul&gt;
        &lt;li style=&quot;font-size: 12px; color: rgb(0, 0, 0);&quot;&gt;Essence Standard (OMG), consulte &lt;u&gt;&lt;a href=&quot;http://www.omg.org/spec/Essence/1.1/&quot; target=&quot;_blank&quot; style=&quot;color: rgb(75, 110, 198);&quot;&gt;http://www.omg.org/spec/Essence/1.1/&lt;/a&gt;&lt;/u&gt;&lt;/li&gt;
        &lt;li style=&quot;font-size: 12px; color: rgb(0, 0, 0);&quot;&gt;A Ess&amp;ecirc;ncia da Engenharia de Software: Aplicando o Kernel SEMAT, por Ivar Jacobson, Pan-Wei Ng, Paul E. McMahon, Ian Spence e Svante Lidman, Addison-Wesley 2013.&lt;/li&gt;
    &lt;/ul&gt;
    &lt;p&gt;&lt;br&gt;&lt;/p&gt;
&lt;/div&gt;</untitled-ontology-3:descricao>
        <untitled-ontology-3:nome>&lt;p&gt;Modelar o sistema&lt;/p&gt;</untitled-ontology-3:nome>
        <untitled-ontology-3:sequenciaEspacoAtividade rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">2</untitled-ontology-3:sequenciaEspacoAtividade>
    </owl:NamedIndividual>
    


