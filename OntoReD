    <!-- http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#EmExecucao -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#EmExecucao">
        <rdf:type rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#PassosElementosPrática"/>
        <untitled-ontology-3:estaContidoEm rdf:resource="http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#MatrizRastreabilidade"/>
        <untitled-ontology-3:descricao>&lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&apos;font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;A matriz de rastreabilidade &amp;eacute; constru&amp;iacute;da considerando o tipo de rastreabilidade, os itens a serem rastreados e seus relacionamentos.&lt;/span&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;strong&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;&amp;nbsp;No entanto, a matriz deve ser preenchida quando todos os requisitos forem negociados e acordados com o cliente no in&amp;iacute;cio do ciclo de desenvolvimento de software&amp;nbsp;&lt;/span&gt;&lt;/strong&gt;&lt;/span&gt;&lt;span style=&apos;font-size: 8px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;(KECHI, 2011)&lt;/span&gt;&lt;span style=&apos;font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;.&lt;/span&gt;&lt;/p&gt;
&lt;ul&gt;
    &lt;li style=&apos;list-style-type: disc; font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;
        &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Na primeira coluna, s&amp;atilde;o informados todos os itens que ser&amp;atilde;o rastreados, os quais podem ser:&amp;nbsp;&lt;/span&gt;&lt;/p&gt;
        &lt;ul style=&quot;font-size: initial;&quot;&gt;
            &lt;li style=&apos;list-style-type: circle; font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;
                &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Os requisitos de neg&amp;oacute;cios, requisitos funcionais, requisitos n&amp;atilde;o funcionais, casos de uso, casos de teste ou m&amp;oacute;dulos de c&amp;oacute;digo.&lt;/span&gt;&lt;/p&gt;
            &lt;/li&gt;
        &lt;/ul&gt;
    &lt;/li&gt;
    &lt;li style=&apos;list-style-type: disc; font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;
        &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Na primeira linha s&amp;atilde;o listados os mesmos elementos ou aqueles que pretende-se rastrear o relacionamento entre eles, conforme a finalidade dessa rastreabilidade.&lt;/span&gt;&lt;/p&gt;
    &lt;/li&gt;
    &lt;li style=&apos;list-style-type: disc; font-size: 12px; font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;
        &lt;p style=&quot;text-align: justify;&quot;&gt;&lt;span style=&apos;font-family: &quot;Times New Roman&quot;, serif;&apos;&gt;Ap&amp;oacute;s, s&amp;atilde;o sinalizados com um &amp;ldquo;X&amp;rdquo; a c&amp;eacute;lula da matriz que deseja-se rastrear o relacionamento entre determinados itens.&lt;/span&gt;&lt;/p&gt;
    &lt;/li&gt;
&lt;/ul&gt;</untitled-ontology-3:descricao>
        <untitled-ontology-3:nome>&lt;p style=&quot;text-align: center;&quot;&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;&lt;strong&gt;Em execu&amp;ccedil;&amp;atilde;o&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;</untitled-ontology-3:nome>
        <untitled-ontology-3:sequencia rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">2</untitled-ontology-3:sequencia>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/vivid/ontologies/2023/2/untitled-ontology-3#EmExecucaoGR -->

